<div class="cvh-wrapper">
   {% if section.settings.video != blank %}
    {{
      section.settings.video
      | video_tag:
        autoplay: true,
        loop: true,
        muted: true,
        controls: false,
        playsinline: true,
        poster: section.settings.poster_image
    }}
  {% elsif section.settings.video_url != blank %}
    <video 
      autoplay 
      muted 
      loop 
      playsinline
      {% if section.settings.poster_image %}
        poster="{{ section.settings.poster_image | image_url: width: 2000 }}"
      {% endif %}
    >
      <source src="{{ section.settings.video_url }}" type="video/mp4">
    </video>
  {% endif %}

  <style>
    html,
    body {
      overflow-x: hidden;
    }
    .cvh-wrapper {
      position: relative;
      width: 100%;
      height: 100vh;
      overflow: hidden;
    }
    .cvh-wrapper video {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }
    .cvh-overlay {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      color: #fff;
      text-align: center;
    }
    .cvh-overlay .btn {
      padding: 10px 20px;
      background: #fff;
      color: #000;
      text-decoration: none;
      margin-top: 10px;
      display: inline-block;
    }
    @media (max-width: 768px) {
      .cvh-wrapper {
        height: 70vh;
        min-height: 500px;
      }
    }
    @media (max-width: 480px) {
      .cvh-wrapper {
        height: 60vh;
        min-height: 450px;
      }
    }
  </style>
</div>

{% schema %}
{
  "name": "Custom Video Hero-2",
  "settings": [
    {
      "type": "video",
      "id": "video",
      "label": "Video File"
    },
    {
      "type": "url",
      "id": "video_url",
      "label": "Video URL (MP4)"
    },
  
  ],
  "presets": [
    {
      "name": "Custom Video Hero-2",
      "category": "Video"
    }
  ]
}
{% endschema %}
