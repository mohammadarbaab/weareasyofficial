<div class="cvh-wrapper">
  <video autoplay muted loop playsinline poster="{{ section.settings.poster_image | asset_url }}">
    {% if section.settings.video_url != blank %}
      <source src="{{ section.settings.video_url }}" type="video/mp4">
    {% elsif section.settings.video != blank %}
      <source src="{{ section.settings.video | asset_url }}" type="video/mp4">
    {% else %}
      <source src="{{ 'vidTrim.mp4' | asset_url }}" type="video/mp4">
    {% endif %}
  </video>

  <style>
    /* Prevent horizontal scroll completely */
    html, body {
      overflow-x: hidden;
    }

    .cvh-wrapper {
      position: relative;
      width: 100%;
      max-width: 100%;
      height: 100vh;
      overflow: hidden;
    }

    .cvh-wrapper video {
      display: block; /* removes inline gap */
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    @media (max-width: 768px) {
      .cvh-wrapper {
        height: 70vh;
        min-height: 500px;
      }
    }

    @media (max-width: 480px) {
      .cvh-wrapper {
        height: 60vh;
        min-height: 450px;
      }
    }
  </style>
</div>