<section class="collection-grid">
  <div class="collection-wrapper">
    <div class="grid">
      {% for block in section.blocks %}
        <div class="collection-item" {{ block.shopify_attributes }}>
          <a href="{{ block.settings.collection.url }}" class="collection-link-wrapper">
            
            {% if block.settings.image != blank %}
              <div class="collection-image-wrapper">
                <img 
                  src="{{ block.settings.image | img_url: '800x1000', crop: 'center' }}" 
                  alt="{{ block.settings.title | escape }}"
                  class="collection-image"
                  loading="lazy"
                >
              </div>
            {% endif %}

            {% if block.settings.title != blank %}
              <div class="collection-title-wrapper">
                <span class="collection-title">{{ block.settings.title }}</span>
                <span class="collection-arrow">→</span>
              </div>
            {% endif %}

          </a>
        </div>
      {% endfor %}
    </div>
    
    <!-- Slider Navigation (visible only on mobile) -->
    <div class="slider-nav">
      <button class="slider-prev" aria-label="Previous slide">←</button>
      <div class="slider-dots"></div>
      <button class="slider-next" aria-label="Next slide">→</button>
    </div>
  </div>
</section>

<style>
/* ========== BASE STYLES ========== */
/* ========== BASE STYLES WITH MODERN DESIGN ========== */
.collection-grid {
  display: flex;
  justify-content: center;
  padding: 80px 20px;
  background: linear-gradient(135deg, #f8f9fa 0%, #ffffff 100%);
  font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  position: relative;
  overflow: hidden;
}

/* Add decorative elements */
.collection-grid::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(0,0,0,0.1), transparent);
}

.collection-grid::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(0,0,0,0.1), transparent);
}

.collection-wrapper {
  max-width: 1400px;
  width: 100%;
  position: relative;
  z-index: 2;
  /* background-color: orange; */

  opacity: 0;
  transform: scale(0.6);
  transform-origin: center;
  transition: transform 0.8s ease, opacity 0.8s ease;
}

.collection-wrapper.show {
  opacity: 1;
  transform: scale(1);
}

/* Section title - optional (you can add via settings) */
.collection-wrapper::before {
  content: 'SHOP BY COLLECTION';
  display: block;
  text-align: center;
  font-size: 14px;
  letter-spacing: 4px;
  text-transform: uppercase;
  color: #999;
  margin-bottom: 20px;
  font-weight: 400;
}

/* ========== GRID LAYOUT WITH MODERN CARD DESIGN ========== */
.grid {
  display: flex;
  justify-content: center;
  gap: 30px;
  flex-wrap: wrap;
  flex-direction: row;
  margin: 0 auto;
  transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
}

/* ========== COLLECTION ITEM WITH GLASSMORPHISM EFFECT ========== */
.collection-item {
  width: 380px;
  text-align: center;
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  flex: 0 0 auto;
  position: relative;
  border-radius: 20px;
  overflow: hidden;
  background: white;
  box-shadow: 0 10px 30px -15px rgba(0,0,0,0.1);
}

.collection-item::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, transparent 60%, rgba(0,0,0,0.4) 100%);
  z-index: 1;
  opacity: 0;
  transition: opacity 0.4s ease;
  pointer-events: none;
  border-radius: 20px;
}

.collection-item:hover {
  transform: translateY(-10px);
  box-shadow: 0 30px 40px -20px rgba(0,0,0,0.3);
}

.collection-item:hover::before {
  opacity: 1;
}

/* ========== LINK WRAPPER ========== */
.collection-link-wrapper {
  text-decoration: none;
  display: block;
  color: inherit;
  position: relative;
}

/* ========== IMAGE STYLES WITH MODERN OVERLAYS ========== */
.collection-image-wrapper {
  width: 100%;
  aspect-ratio: 3 / 4;
  overflow: hidden;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  position: relative;
}

.collection-image-wrapper::after {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 50%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
  transform: skewX(-25deg);
  transition: left 0.8s ease;
  z-index: 2;
}

.collection-item:hover .collection-image-wrapper::after {
  left: 150%;
}

.collection-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.8s cubic-bezier(0.4, 0, 0.2, 1);
  filter: brightness(0.95);
}

.collection-item:hover .collection-image {
  transform: scale(1.08);
  filter: brightness(1.05);
}

/* ========== TITLE STYLES WITH MODERN TYPOGRAPHY ========== */
.collection-title-wrapper {
  margin-top: 0px;
  padding: 20px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
  font-size: 20px;
  font-weight: 500;
  letter-spacing: 0.5px;
  color: #1a1a1a;
  border-bottom: 2px solid transparent;
  transition: all 0.3s ease;
  position: relative;
  background: white;
  z-index: 3;
}

.collection-title {
  text-transform: uppercase;
  font-size: 20px;
  font-weight: 600;
  letter-spacing: 1px;
  background: linear-gradient(135deg, #1a1a1a 0%, #333333 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.collection-arrow {
  font-size: 24px;
  line-height: 1;
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  color: #1a1a1a;
  width: 40px;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #f5f5f5;
}

.collection-item:hover .collection-arrow {
  transform: translateX(8px) rotate(0deg);
  background: #1a1a1a;
  color: white;
}

.collection-item:hover .collection-title-wrapper {
  border-bottom-color: #1a1a1a;
}

/* ========== SLIDER STYLES WITH MODERN DESIGN ========== */
.slider-nav {
  display: none;
  justify-content: center;
  align-items: center;
  gap: 30px;
  margin-top: 50px;
}

.slider-prev,
.slider-next {
  width: 50px;
  height: 50px;
  border-radius: 50%;
  background: white;
  border: none;
  color: #1a1a1a;
  font-size: 22px;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 5px 20px rgba(0,0,0,0.1);
  position: relative;
  overflow: hidden;
}

.slider-prev::before,
.slider-next::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 0;
  height: 0;
  border-radius: 50%;
  background: rgba(0,0,0,0.05);
  transform: translate(-50%, -50%);
  transition: width 0.4s ease, height 0.4s ease;
}

.slider-prev:hover::before,
.slider-next:hover::before {
  width: 100%;
  height: 100%;
}

.slider-prev:hover,
.slider-next:hover {
  background: #1a1a1a;
  color: white;
  transform: scale(1.05);
}

.slider-prev:active,
.slider-next:active {
  transform: scale(0.95);
}

.slider-dots {
  display: flex;
  gap: 12px;
}

.slider-dot {
  width: 10px;
  height: 10px;
  border-radius: 50%;
  background: #ddd;
  cursor: pointer;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
}

.slider-dot::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 0;
  height: 0;
  border-radius: 50%;
  background: rgba(0,0,0,0.1);
  transform: translate(-50%, -50%);
  transition: width 0.3s ease, height 0.3s ease;
}

.slider-dot:hover::after {
  width: 20px;
  height: 20px;
}

.slider-dot.active {
  background: #1a1a1a;
  transform: scale(1.3);
  box-shadow: 0 0 0 3px rgba(0,0,0,0.1);
}

/* ========== RESPONSIVE DESIGN WITH MODERN BREAKPOINTS ========== */
@media (max-width: 1240px) {
  .collection-grid {
    padding: 60px 20px;
  }
  
  .grid {
    gap: 25px;
    flex-wrap: nowrap;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding: 5px 5px 20px;
    justify-content: flex-start;
    cursor: grab;
  }
  
  .grid:active {
    cursor: grabbing;
  }
  
  .grid::-webkit-scrollbar {
    display: none;
  }
  
  .collection-item {
    width: 300px;
    scroll-snap-align: start;
    flex: 0 0 auto;
  }
  
  .collection-title,
  .collection-arrow {
    font-size: 18px;
  }
  
  .collection-title-wrapper {
    margin-top: 20px;
    padding: 0 12px 15px;
  }
  
  .collection-arrow {
    width: 35px;
    height: 35px;
    font-size: 20px;
  }
  
  .slider-nav {
    display: flex;
  }
}

@media (max-width: 768px) {
  .collection-grid {
    padding: 50px 15px;
  }
  
  .collection-wrapper::before {
    font-size: 12px;
    letter-spacing: 3px;
    margin-bottom: 15px;
  }
  
  .grid {
    gap: 20px;
  }
  
  .collection-item {
    width: 280px;
  }
  
  .collection-title-wrapper {
    margin-top: 18px;
  }
  
  .collection-title {
    font-size: 16px;
  }
  
  .collection-arrow {
    width: 32px;
    height: 32px;
    font-size: 18px;
  }
  
  .slider-nav {
    gap: 25px;
    margin-top: 40px;
  }
  
  .slider-prev,
  .slider-next {
    width: 44px;
    height: 44px;
    font-size: 20px;
  }
}

@media (max-width: 480px) {
  .collection-grid {
    padding: 40px 12px;
  }
  
  .collection-wrapper::before {
    font-size: 11px;
    letter-spacing: 2px;
    margin-bottom: 12px;
  }
  
  .grid {
    gap: 15px;
    padding-bottom: 15px;
  }
  
  .collection-item {
    width: 240px;
    max-width: 75vw;
  }
  
  .collection-title-wrapper {
    margin-top: 15px;
    padding: 0 10px 12px;
  }
  
  .collection-title {
    font-size: 14px;
    letter-spacing: 0.5px;
  }
  
  .collection-arrow {
    width: 28px;
    height: 28px;
    font-size: 16px;
  }
  
  .slider-nav {
    gap: 20px;
    margin-top: 30px;
  }
  
  .slider-prev,
  .slider-next {
    width: 38px;
    height: 38px;
    font-size: 18px;
  }
  
  .slider-dot {
    width: 8px;
    height: 8px;
  }
  
  .slider-dot.active {
    transform: scale(1.2);
  }
}

/* ========== TOUCH DEVICE OPTIMIZATION ========== */
@media (hover: none) and (pointer: coarse) {
  .collection-item:hover {
    transform: none;
    box-shadow: 0 10px 30px -15px rgba(0,0,0,0.1);
  }
  
  .collection-item:hover::before {
    opacity: 0;
  }
  
  .collection-item:hover .collection-image {
    transform: none;
  }
  
  .collection-item:hover .collection-image-wrapper::after {
    left: -100%;
  }
  
  .collection-item:hover .collection-arrow {
    transform: translateX(8px);
    background: #f5f5f5;
    color: #1a1a1a;
  }
  
  .collection-arrow {
    transform: translateX(8px);
  }
  
  .grid {
    -webkit-overflow-scrolling: touch;
  }
  
  .slider-prev,
  .slider-next {
    -webkit-tap-highlight-color: transparent;
  }
  
  .slider-prev:active,
  .slider-next:active {
    background: #1a1a1a;
    color: white;
    transform: scale(0.95);
  }
}

/* ========== DARK MODE SUPPORT ========== */
@media (prefers-color-scheme: dark) {
  .collection-grid {
    background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 100%);
  }
  
  .collection-grid::before,
  .collection-grid::after {
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.1), transparent);
  }
  
  .collection-wrapper::before {
    color: #999;
  }
  
  .collection-item {
    background: #2d2d2d;
    box-shadow: 0 10px 30px -15px rgba(0,0,0,0.5);
  }
  
  .collection-title-wrapper {
    background: #2d2d2d;
  }
  
  .collection-title {
    background: linear-gradient(135deg, #ffffff 0%, #cccccc 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  
  .collection-arrow {
    background: #404040;
    color: #ffffff;
  }
  
  .collection-item:hover .collection-arrow {
    background: #ffffff;
    color: #1a1a1a;
  }
  
  .slider-prev,
  .slider-next {
    background: #2d2d2d;
    color: #ffffff;
    box-shadow: 0 5px 20px rgba(0,0,0,0.3);
  }
  
  .slider-prev:hover,
  .slider-next:hover {
    background: #ffffff;
    color: #1a1a1a;
  }
  
  .slider-dot {
    background: #404040;
  }
  
  .slider-dot.active {
    background: #ffffff;
    box-shadow: 0 0 0 3px rgba(255,255,255,0.1);
  }
}

/* ========== ANIMATIONS ========== */
@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(30px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.collection-item {
  animation: fadeInUp 0.6s ease forwards;
  opacity: 0;
}

.collection-item:nth-child(1) { animation-delay: 0.1s; }
.collection-item:nth-child(2) { animation-delay: 0.2s; }
.collection-item:nth-child(3) { animation-delay: 0.3s; }
.collection-item:nth-child(4) { animation-delay: 0.4s; }
.collection-item:nth-child(5) { animation-delay: 0.5s; }
.collection-item:nth-child(6) { animation-delay: 0.6s; }
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const grid = document.querySelector('.grid');
  const items = document.querySelectorAll('.collection-item');
  const prevBtn = document.querySelector('.slider-prev');
  const nextBtn = document.querySelector('.slider-next');
  const dotsContainer = document.querySelector('.slider-dots');

  if (!grid || items.length === 0 || !prevBtn || !nextBtn || !dotsContainer) return;

  let currentIndex = 0;
  let itemWidth = 0;
  let visibleItems = 1;
  let sliderInitialized = false;

  function createDots() {
    dotsContainer.innerHTML = '';
    for (let i = 0; i < items.length; i++) {
      const dot = document.createElement('span');
      dot.classList.add('slider-dot');
      if (i === currentIndex) dot.classList.add('active');
      dot.addEventListener('click', () => scrollToIndex(i));
      dotsContainer.appendChild(dot);
    }
  }

  function updateDots() {
    const dots = document.querySelectorAll('.slider-dot');
    dots.forEach((dot, index) => {
      dot.classList.toggle('active', index === currentIndex);
    });
  }

  function calculateVisibleItems() {
    if (window.innerWidth <= 480) {
      visibleItems = 1;
    } else if (window.innerWidth <= 768) {
      visibleItems = 2;
    } else {
      visibleItems = 3;
    }

    const gap = window.innerWidth <= 768 ? 20 : 30;
    itemWidth = items[0].offsetWidth;

    return gap;
  }

  function scrollToIndex(index) {
    const gap = window.innerWidth <= 768 ? 20 : 30;

    if (index < 0) index = 0;
    if (index > items.length - visibleItems) {
      index = Math.max(0, items.length - visibleItems);
    }

    currentIndex = index;

    const scrollAmount = currentIndex * (itemWidth + gap);

    grid.scrollTo({
      left: scrollAmount,
      behavior: 'smooth'
    });

    updateDots();
  }

  function nextSlide() {
    scrollToIndex(currentIndex + 1);
  }

  function prevSlide() {
    scrollToIndex(currentIndex - 1);
  }

  function initSlider() {
    if (window.innerWidth <= 768) {
      calculateVisibleItems();

      if (!sliderInitialized) {
        createDots();
        nextBtn.addEventListener('click', nextSlide);
        prevBtn.addEventListener('click', prevSlide);

        grid.addEventListener('scroll', function() {
          const gap = window.innerWidth <= 768 ? 20 : 30;
          const newIndex = Math.round(grid.scrollLeft / (itemWidth + gap));

          if (newIndex !== currentIndex) {
            currentIndex = newIndex;
            updateDots();
          }
        });

        sliderInitialized = true;
      }
    } else {
      // Reset on desktop
      grid.scrollTo({ left: 0 });
      currentIndex = 0;
      sliderInitialized = false;
      dotsContainer.innerHTML = '';
    }
  }

  window.addEventListener('resize', function() {
    initSlider();
  });

  initSlider();
});

const wrapper = document.querySelector(".collection-wrapper");

const observer = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      entry.target.classList.add("show");
    }
  });
}, { threshold: 0.3 });

observer.observe(wrapper);
</script>

{% schema %}
{
  "name": "Collection Grid",
  "blocks": [
    {
      "type": "item",
      "name": "Collection Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "COLLECTION"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection Grid",
      "category": "Collections"
    }
  ]
}
{% endschema %}