{% comment %}
  Featured Collection Section - Premium Version
  Color Scheme: #F7F3EE (Warm Beige)
  Fully Responsive | Modern E-commerce Design
{% endcomment %}

<section class="featured-collection">
  <div class="container">
    <!-- Section Header -->
    <div class="section-header">
      {% if section.settings.subheading != blank %}
        <span class="section-subtitle">{{ section.settings.subheading }}</span>
      {% endif %}
      
      {% if section.settings.heading != blank %}
        <h2 class="section-title">{{ section.settings.heading }}</h2>
      {% endif %}
      
      {% if section.settings.description != blank %}
        <p class="section-description">{{ section.settings.description }}</p>
      {% endif %}
      
      <div class="section-divider">
        <span class="divider-line"></span>
        <span class="divider-icon">✦</span>
        <span class="divider-line"></span>
      </div>
    </div>

    <!-- Products Grid -->
    {% if section.settings.products.size > 0 %}
      <div class="products-grid">
        {% for product in section.settings.products limit: section.settings.products_limit %}
          {% assign has_sale = false %}
          {% if product.compare_at_price > product.price %}
            {% assign has_sale = true %}
          {% endif %}
          
          <div class="product-card" data-product-id="{{ product.id }}" data-index="{{ forloop.index0 }}">
            <div class="product-card-inner">
              
              <!-- Product Badges -->
              {% comment %} <div class="product-badges">
                {% if has_sale %}
                  <span class="badge badge-sale">SALE</span>
                {% endif %}
                
                {% if product.tags contains 'new' %}
                  <span class="badge badge-new">NEW</span>
                {% endif %}
                
                {% if product.tags contains 'bestseller' %}
                  <span class="badge badge-bestseller">BESTSELLER</span>
                {% endif %}
              </div> {% endcomment %}

              <!-- Product Image with Hover Effect -->
              <div class="product-image-wrapper">
                <a href="{{ product.url }}" class="product-image-link">
                  <div class="product-image-main">
                    {% if product.featured_image %}
                      <img
                        src="{{ product.featured_image | image_url: width: 600 }}"
                        alt="{{ product.title | escape }}"
                        class="product-image product-image-front"
                        loading="lazy"
                        width="600"
                        height="600"
                      >
                      
                      {% if product.images.size > 1 %}
                        <img
                          src="{{ product.images[1] | image_url: width: 600 }}"
                          alt="{{ product.title | escape }}"
                          class="product-image product-image-hover"
                          loading="lazy"
                          width="600"
                          height="600"
                        >
                      {% endif %}
                    {% else %}
                      <div class="product-image-placeholder">
                        <span>No image</span>
                      </div>
                    {% endif %}
                  </div>
                </a>

                <!-- Quick Action Buttons -->
                <div class="product-actions">
                  <button class="action-btn quick-view-btn" data-product-handle="{{ product.handle }}" aria-label="Quick view">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <circle cx="12" cy="12" r="3"></circle>
                      <path d="M22 12c-2.667 4.667-6 7-10 7s-7.333-2.333-10-7c2.667-4.667 6-7 10-7s7.333 2.333 10 7z"></path>
                    </svg>
                  </button>
                  
                  <button class="action-btn wishlist-btn" data-product-handle="{{ product.handle }}" aria-label="Add to wishlist">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
                    </svg>
                  </button>
                </div>

                <!-- Add to Cart Button (on image hover) -->
                <div class="product-add-to-cart">
                  <form method="post" action="/cart/add" class="add-to-cart-form">
                    <input type="hidden" name="id" value="{{ product.variants.first.id }}">
                    <button type="submit" class="add-to-cart-btn" data-product-id="{{ product.id }}">
                      <span class="btn-text">Add to Cart</span>
                      <span class="btn-icon">→</span>
                    </button>
                  </form>
                </div>
              </div>

              <!-- Product Info -->
              <div class="product-info">
                {% if section.settings.show_vendor and product.vendor != blank %}
                  <div class="product-vendor">{{ product.vendor }}</div>
                {% endif %}
                
                <h3 class="product-title">
                  <a href="{{ product.url }}">{{ product.title }}</a>
                </h3>
                
                <!-- Product Rating -->
                {% if section.settings.show_rating %}
                  <div class="product-rating">
                    <div class="rating-stars">
                      <span class="star">★</span>
                      <span class="star">★</span>
                      <span class="star">★</span>
                      <span class="star">★</span>
                      <span class="star">★</span>
                    </div>
                    <span class="rating-count">({{ product.metafields.reviews.rating_count | default: 12 }})</span>
                  </div>
                {% endif %}

                <!-- Product Price -->
                <div class="product-price">
                  {% if has_sale %}
                    <span class="price-compare">{{ product.compare_at_price | money }}</span>
                    <span class="price-sale">{{ product.price | money }}</span>
                  {% else %}
                    <span class="price-regular">{{ product.price | money }}</span>
                  {% endif %}
                </div>

                <!-- Color Options (if available) -->
                {% if product.options contains 'Color' and section.settings.show_color_options %}
                  <div class="product-colors">
                    {% assign color_option_index = 0 %}
                    {% for option in product.options %}
                      {% if option == 'Color' or option == 'Colour' %}
                        {% assign color_option_index = forloop.index0 %}
                        {% assign values = '' %}
                        {% for variant in product.variants %}
                          {% unless values contains variant.options[color_option_index] %}
                            {% assign values = values | append: variant.options[color_option_index] | append: ',' %}
                            <span class="color-dot" style="background-color: {{ variant.options[color_option_index] | handleize }}" title="{{ variant.options[color_option_index] }}"></span>
                          {% endunless %}
                        {% endfor %}
                      {% endif %}
                    {% endfor %}
                  </div>
                {% endif %}
              </div>
            </div>
          </div>
        {% endfor %}
      </div>

      <!-- View All Button -->
      {% if section.settings.show_view_all %}
        <div class="view-all-container">
          <a href="{{ section.settings.view_all_link | default: '/collections/all' }}" class="view-all-btn">
            {{ section.settings.view_all_text | default: 'View All Products' }}
            <span class="btn-arrow">→</span>
          </a>
        </div>
      {% endif %}

    {% else %}
      <!-- Empty State -->
      <div class="empty-state">
        <p>No products selected. Please select products in the theme settings.</p>
      </div>
    {% endif %}
  </div>
</section>

<style>
/* =============================================================================
  FEATURED COLLECTION - PREMIUM EDITION
  Color Scheme: #F7F3EE (Warm Beige)
  ============================================================================= */

/* CSS Variables */
:root {
  --fc-bg: #F7F3EE;
  --fc-primary: #C7A14A;
  --fc-primary-dark: #A8863A;
  --fc-primary-light: rgba(199, 161, 74, 0.15);
  --fc-text-dark: #1A1A1A;
  --fc-text-light: #666666;
  --fc-text-muted: #999999;
  --fc-white: #FFFFFF;
  --fc-offwhite: #F9F9F9;
  --fc-border: #E5E5E5;
  --fc-border-light: #F0F0F0;
  --fc-success: #10B981;
  --fc-danger: #EF4444;
  --fc-warning: #F59E0B;
  
  /* Shadows */
  --fc-shadow-sm: 0 10px 30px -10px rgba(0, 0, 0, 0.05);
  --fc-shadow-md: 0 20px 40px -12px rgba(0, 0, 0, 0.08);
  --fc-shadow-lg: 0 30px 60px -12px rgba(199, 161, 74, 0.15);
  --fc-shadow-hover: 0 30px 50px -15px rgba(199, 161, 74, 0.25);
  
  /* Transitions */
  --fc-transition: all 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  --fc-transition-bounce: all 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
  
  /* Border Radius */
  --fc-radius-sm: 8px;
  --fc-radius-md: 12px;
  --fc-radius-lg: 20px;
  --fc-radius-xl: 30px;
  --fc-radius-full: 9999px;
}

/* Base Section Styles */
.featured-collection {
  padding: 30px 20px 20px;
  background: #F7F3EE;
  /* background-color: red; 
  /* background-color: var(--fc-bg); */
  position: relative;
  overflow: hidden;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
}

.featured-collection::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 100%;
  background: radial-gradient(circle at 0% 0%, rgba(199, 161, 74, 0.03) 0%, transparent 70%);
  pointer-events: none;
}

.container {
  max-width: 1400px;
  margin: 0 auto;
  padding: 0 20px;
  position: relative;
  {% comment %} background-color: red;  {% endcomment %}

  z-index: 2;
}

/* =============================================================================
  Section Header
  ============================================================================= */

.section-header {
  text-align: center;
  margin-bottom: 40px;
  animation: fadeInUp 0.8s ease forwards;
}

.section-subtitle {
  display: inline-block;
  font-size: 14px;
  font-weight: 600;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: var(--fc-primary);
  margin-bottom: 15px;
  padding: 0 20px;
  position: relative;
}

.section-subtitle::before,
.section-subtitle::after {
  content: '';
  position: absolute;
  top: 50%;
  width: 30px;
  height: 1px;
  background: linear-gradient(90deg, transparent, var(--fc-primary), transparent);
}

.section-subtitle::before {
  left: -15px;
}

.section-subtitle::after {
  right: -15px;
}

.section-title {
  font-size: clamp(32px, 5vw, 48px);
  font-weight: 600;
  color: var(--fc-text-dark);
  margin: 0 0 20px;
  line-height: 1.2;
  letter-spacing: -0.02em;
}

.section-description {
  font-size: 18px;
  color: var(--fc-text-light);
  max-width: 600px;
  margin: 0 auto 30px;
  line-height: 1.6;
}

.section-divider {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20px;
}

.divider-line {
  width: 60px;
  height: 2px;
  background: linear-gradient(90deg, transparent, var(--fc-primary), transparent);
  border-radius: 2px;
}

.divider-icon {
  color: var(--fc-primary);
  font-size: 20px;
  animation: rotate 4s linear infinite;
}

/* =============================================================================
  Products Grid
  ============================================================================= */

.products-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 30px;
  margin-bottom: 40px;
  {% comment %} background-color:orange; {% endcomment %}
}

/* Product Card */
.product-card {
  opacity: 0;
  transform: translateY(30px);
  animation: fadeInUp 0.6s ease forwards;
  {% comment %} background-color:gray; {% endcomment %}
}

/* Stagger animation for cards */
{% for i in (1..12) %}
.product-card:nth-child({{ i }}) {
  animation-delay: {{ i | times: 0.1 }}s;
}
{% endfor %}

.product-card-inner {
  /* background: var(--fc-white);
   */
   background-color: #10B981;
  {% comment %} border-radius: var(--fc-radius-lg); {% endcomment %}
  overflow: hidden;
  box-shadow: var(--fc-shadow-sm);
  transition: var(--fc-transition-bounce);
  position: relative;
  height: 100%;
  display: flex;
  flex-direction: column;
  {% comment %} border: 1px solid var(--fc-border-light); {% endcomment %}
}

.product-card-inner:hover {
  transform: translateY(-8px);
  box-shadow: var(--fc-shadow-hover);
  border-color: transparent;
}

/* Product Badges */
.product-badges {
  position: absolute;
  top: 16px;
  left: 16px;
  z-index: 10;
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.badge {
  padding: 6px 14px;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 1px;
  text-transform: uppercase;
  border-radius: var(--fc-radius-full);
  background: var(--fc-white);
  color: var(--fc-text-dark);
  box-shadow: 0 4px 10px rgba(0, 0, 0, 0.05);
  animation: badgePop 0.4s ease;
  border: 1px solid var(--fc-border-light);
  backdrop-filter: blur(4px);
}

.badge-sale {
  background: var(--fc-danger);
  color: var(--fc-white);
  border-color: var(--fc-danger);
}

.badge-new {
  background: var(--fc-primary);
  color: var(--fc-white);
  border-color: var(--fc-primary);
}

.badge-bestseller {
  background: var(--fc-warning);
  color: var(--fc-white);
  border-color: var(--fc-warning);
}

/* Product Image */
.product-image-wrapper {
  position: relative;
  overflow: hidden;
  aspect-ratio: 3/4;
  background: linear-gradient(45deg, var(--fc-bg), var(--fc-offwhite));
  background-color:blue;
  
}

.product-image-link {
  display: block;
  width: 100%;
  height: 100%;
  text-decoration: none;
}

.product-image-main {
  position: relative;
  width: 100%;
  height: 100%;
  background-color:orange;
}

.product-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.8s cubic-bezier(0.2, 0.75, 0.3, 1);
  display: block;
  background-color:
}

.product-image-front {
  position: relative;
  z-index: 1;
}

.product-image-hover {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  opacity: 0;
  z-index: 2;
  transition: opacity 0.5s ease;
}

.product-image-wrapper:hover .product-image-front {
  transform: scale(1.1);
}

.product-image-wrapper:hover .product-image-hover {
  opacity: 1;
}

/* Image Placeholder */
.product-image-placeholder {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, var(--fc-bg) 0%, var(--fc-border) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--fc-text-muted);
  font-size: 14px;
}

/* Quick Action Buttons */
.product-actions {
  position: absolute;
  top: 16px;
  right: 16px;
  z-index: 20;
  display: flex;
  flex-direction: column;
  gap: 10px;
  opacity: 0;
  transform: translateX(20px);
  transition: var(--fc-transition-bounce);
}

.product-image-wrapper:hover .product-actions {
  opacity: 1;
  transform: translateX(0);
}

.action-btn {
  width: 44px;
  height: 44px;
  border-radius: var(--fc-radius-full);
  background: var(--fc-white);
  border: none;
  box-shadow: 0 8px 20px rgba(0, 0, 0, 0.1);
  cursor: pointer;
  transition: var(--fc-transition);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--fc-text-dark);
  position: relative;
  backdrop-filter: blur(4px);
  background: rgba(255, 255, 255, 0.95);
  border: 1px solid var(--fc-border-light);
}

.action-btn:hover {
  background: var(--fc-primary);
  color: var(--fc-white);
  transform: scale(1.1) rotate(5deg);
  box-shadow: 0 12px 25px rgba(199, 161, 74, 0.3);
  border-color: var(--fc-primary);
}

.action-btn:active {
  transform: scale(0.95);
}

.action-btn svg {
  stroke: currentColor;
  stroke-width: 2.2;
  transition: all 0.2s;
}

.action-btn.wishlist-btn.active svg {
  fill: var(--fc-danger);
  stroke: var(--fc-danger);
}

/* Add to Cart Button (on image) */
.product-add-to-cart {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 15;
  transform: translateY(100%);
  transition: var(--fc-transition);
  padding: 16px;
}

.product-image-wrapper:hover .product-add-to-cart {
  transform: translateY(0);
}

.add-to-cart-btn {
  width: 100%;
  padding: 14px 20px;
  background: var(--fc-text-dark);
  color: var(--fc-white);
  border: none;
  border-radius: var(--fc-radius-md);
  font-size: 14px;
  font-weight: 600;
  letter-spacing: 1px;
  text-transform: uppercase;
  cursor: pointer;
  transition: var(--fc-transition);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);
}

.add-to-cart-btn:hover {
  background: var(--fc-primary);
  gap: 15px;
}

.add-to-cart-btn .btn-icon {
  opacity: 0;
  transform: translateX(-10px);
  transition: var(--fc-transition);
}

.add-to-cart-btn:hover .btn-icon {
  opacity: 1;
  transform: translateX(0);
}


.add-to-cart-btn.added {
  background: var(--fc-success);
  pointer-events: none;
}

/* Product Info */
.product-info {
  padding: 20px;
  background: #F7F3EE;
  flex: 1;
  display: flex;
  flex-direction: column;
}

.product-vendor {
  font-size: 12px;
  font-weight: 500;
  color: var(--fc-primary);
  text-transform: uppercase;
  letter-spacing: 1.5px;
  margin-bottom: 0px;
  {% comment %} background-color:gray; {% endcomment %}
}

.product-title {
  font-size: 18px;
  font-weight: 500;
  {% comment %} margin-bottom: 10px; {% endcomment %}
  {% comment %} background-color:red; {% endcomment %}
  line-height: 1.4;
}

.product-title a {
  color: var(--fc-text-dark);
  text-decoration: none;
  transition: color 0.2s;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.product-title a:hover {
  color: var(--fc-primary);
}

/* Rating */
.product-rating {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 6px;
}

.rating-stars {
  display: flex;
  gap: 2px;
}

.star {
  color: #FFD700;
  font-size: 14px;
  filter: drop-shadow(0 2px 2px rgba(255, 215, 0, 0.2));
}

.rating-count {
  font-size: 13px;
  color: var(--fc-text-muted);
}

/* Price */
.product-price {
  margin-bottom: 10px;
  display: flex;
  align-items: center;
  gap: 10px;
  flex-wrap: wrap;
}

.price-regular {
  font-size: 20px;
  font-weight: 600;
  color: var(--fc-text-dark);
}

.price-sale {
  font-size: 20px;
  font-weight: 700;
  color: var(--fc-danger);
}

.price-compare {
  font-size: 16px;
  color: var(--fc-text-muted);
  text-decoration: line-through;
}

/* Color Options */
.product-colors {
  display: flex;
  gap: 8px;
  margin-top: auto;
  flex-wrap: wrap;
}

.color-dot {
  width: 28px;
  height: 28px;
  border-radius: var(--fc-radius-full);
  cursor: pointer;
  transition: var(--fc-transition-bounce);
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  border: 2px solid var(--fc-white);
}

.color-dot:hover {
  transform: scale(1.2);
  box-shadow: 0 5px 15px rgba(199, 161, 74, 0.3);
}

/* View All Button */
.view-all-container {
  text-align: center;
  margin-top: 40px;
}

.view-all-btn {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  padding: 16px 40px;
  background: transparent;
  color: var(--fc-text-dark);
  text-decoration: none;
  font-size: 16px;
  font-weight: 600;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  border: 2px solid var(--fc-text-dark);
  border-radius: var(--fc-radius-full);
  transition: var(--fc-transition);
  position: relative;
  overflow: hidden;
}

.view-all-btn::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 0;
  height: 0;
  border-radius: 50%;
  background: var(--fc-text-dark);
  transform: translate(-50%, -50%);
  transition: width 0.6s, height 0.6s;
  z-index: -1;
}

.view-all-btn:hover {
  color: var(--fc-white);
  border-color: var(--fc-text-dark);
}

.view-all-btn:hover::before {
  width: 300px;
  height: 300px;
}

.view-all-btn .btn-arrow {
  transition: transform 0.3s;
}

.view-all-btn:hover .btn-arrow {
  transform: translateX(5px);
}

/* Empty State */
.empty-state {
  text-align: center;
  padding: 80px 20px;
  background: var(--fc-white);
  border-radius: var(--fc-radius-lg);
  color: var(--fc-text-muted);
  font-size: 16px;
  border: 2px dashed var(--fc-border);
}

/* =============================================================================
  Animations
  ============================================================================= */

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(30px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes badgePop {
  0% {
    opacity: 0;
    transform: scale(0.8) rotate(-5deg);
  }
  50% {
    transform: scale(1.1) rotate(2deg);
  }
  100% {
    opacity: 1;
    transform: scale(1) rotate(0);
  }
}

@keyframes rotate {
  from {
    transform: rotate(0deg);
  }
  to {
    transform: rotate(360deg);
  }
}

/* =============================================================================
  Responsive Design
  ============================================================================= */

/* Large Desktop */
@media (min-width: 1200px) and (max-width: 1400px) {
  .products-grid {
    grid-template-columns: repeat(4, 1fr);
    gap: 25px;
  }
}

/* Desktop */
@media (max-width: 1199px) {
  .products-grid {
    grid-template-columns: repeat(3, 1fr);
    gap: 25px;
  }
}

/* Tablet */
@media (max-width: 991px) {
  .products-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }
  
  .featured-collection {
    padding: 60px 15px;
  }
  
  .section-header {
    margin-bottom: 40px;
  }
  
  .section-title {
    font-size: 36px;
  }
  
  .section-description {
    font-size: 16px;
    padding: 0 15px;
  }
  
  .product-title {
    font-size: 16px;
  }
  
  .price-regular,
  .price-sale {
    font-size: 18px;
  }
}

/* Mobile Landscape */
@media (max-width: 767px) {
  .products-grid {
    grid-template-columns: repeat(2, 1fr) !important;
    gap: 8px;
  }

