<script>
document.addEventListener('DOMContentLoaded', function() {
  'use strict';
  
  // ===========================================================================
  // Wishlist Functionality
  // ===========================================================================
  class WishlistManager {
    constructor() {
      this.wishlistKey = 'wishlist_items';
      this.wishlist = this.getWishlist();
      this.init();
    }
    
    getWishlist() {
      try {
        return JSON.parse(localStorage.getItem(this.wishlistKey)) || [];
      } catch (e) {
        console.error('Error reading wishlist:', e);
        return [];
      }
    }
    
    saveWishlist() {
      try {
        localStorage.setItem(this.wishlistKey, JSON.stringify(this.wishlist));
      } catch (e) {
        console.error('Error saving wishlist:', e);
      }
    }
    
    addToWishlist(productHandle) {
      if (!this.wishlist.includes(productHandle)) {
        this.wishlist.push(productHandle);
        this.saveWishlist();
        this.showNotification('Added to wishlist ❤️', 'success');
        return true;
      }
      return false;
    }
    
    removeFromWishlist(productHandle) {
      const index = this.wishlist.indexOf(productHandle);
      if (index > -1) {
        this.wishlist.splice(index, 1);
        this.saveWishlist();
        this.showNotification('Removed from wishlist', 'info');
        return true;
      }
      return false;
    }
    
    isInWishlist(productHandle) {
      return this.wishlist.includes(productHandle);
    }
    
    toggleWishlist(productHandle, button) {
      if (this.isInWishlist(productHandle)) {
        this.removeFromWishlist(productHandle);
        button.classList.remove('active');
      } else {
        this.addToWishlist(productHandle);
        button.classList.add('active');
      }
    }
    
    showNotification(message, type = 'info') {
      const notification = document.createElement('div');
      notification.className = `notification notification-${type}`;
      notification.textContent = message;
      notification.style.cssText = `
        position: fixed;
        top: 20px;
        right: 20px;
        background: ${type === 'success' ? '#10B981' : '#1A1A1A'};
        color: white;
        padding: 12px 24px;
        border-radius: 8px;
        font-size: 14px;
        font-weight: 500;
        z-index: 9999;
        animation: slideIn 0.3s ease;
        box-shadow: 0 5px 25px rgba(0,0,0,0.2);
      `;
      
      document.body.appendChild(notification);
      
      setTimeout(() => {
        notification.style.animation = 'slideOut 0.3s ease';
        setTimeout(() => {
          notification.remove();
        }, 300);
      }, 2000);
    }
    
    init() {
      // Initialize wishlist buttons
      document.querySelectorAll('.wishlist-btn').forEach(btn => {
        const productHandle = btn.dataset.productHandle;
        if (this.isInWishlist(productHandle)) {
          btn.classList.add('active');
        }
        
        btn.addEventListener('click', (e) => {
          e.preventDefault();
          e.stopPropagation();
          this.toggleWishlist(productHandle, btn);
        });
      });
    }
  }

  // ===========================================================================
  // Quick View Functionality
  // ===========================================================================
  class QuickViewManager {
    constructor() {
      this.init();
    }
    
    openQuickView(productHandle) {
      // Add loading animation
      const btn = event.currentTarget;
      btn.style.transform = 'scale(0.9)';
      setTimeout(() => {
        btn.style.transform = '';
      }, 200);
      
      // Show notification (replace with actual modal)
      this.showNotification(`Quick view: ${productHandle}`);
      console.log('Quick view for:', productHandle);
      
      // You can implement your modal here
      // this.loadQuickViewContent(productHandle);
    }
    
    showNotification(message) {
      const notification = document.createElement('div');
      notification.className = 'notification notification-info';
      notification.textContent = message;
      notification.style.cssText = `
        position: fixed;
        top: 20px;
        right: 20px;
        background: #1A1A1A;
        color: white;
        padding: 12px 24px;
        border-radius: 8px;
        font-size: 14px;
        font-weight: 500;
        z-index: 9999;
        animation: slideIn 0.3s ease;
        box-shadow: 0 5px 25px rgba(0,0,0,0.2);
      `;
      
      document.body.appendChild(notification);
      
      setTimeout(() => {
        notification.style.animation = 'slideOut 0.3s ease';
        setTimeout(() => {
          notification.remove();
        }, 300);
      }, 2000);
    }
    
    init() {
      document.querySelectorAll('.quick-view-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
          e.preventDefault();
          e.stopPropagation();
          const productHandle = btn.dataset.productHandle;
          this.openQuickView(productHandle);
        });
      });
    }
  }

  // ===========================================================================
  // Add to Cart Functionality
  // ===========================================================================
  class CartManager {
    constructor() {
      this.init();
    }
    
    async addToCart(event, form) {
      event.preventDefault();
      
      const button = form.querySelector('.add-to-cart-btn');
      const originalText = button.querySelector('.btn-text').textContent;
      
      // Add loading state
      button.classList.add('added');
      button.querySelector('.btn-text').textContent = 'ADDED!';
      
      // Show success notification
      this.showNotification('Added to cart successfully! 🛒');
      
      // Get form data
      const formData = new FormData(form);
      
      try {
        // Make AJAX request to add to cart
        const response = await fetch('/cart/add.js', {
          method: 'POST',
          body: formData
        });
        
        if (response.ok) {
          // Update cart count if needed
          this.updateCartCount();
        } else {
          throw new Error('Failed to add to cart');
        }
      } catch (error) {
        console.error('Cart error:', error);
        button.classList.remove('added');
        button.querySelector('.btn-text').textContent = originalText;
        this.showNotification('Error adding to cart', 'error');
      }
      
      // Reset button after 2 seconds
      setTimeout(() => {
        button.classList.remove('added');
        button.querySelector('.btn-text').textContent = originalText;
      }, 2000);
    }
    
    updateCartCount() {
      // Implement cart count update
      fetch('/cart.js')
        .then(response => response.json())
        .then(cart => {
          const cartCountElements = document.querySelectorAll('.cart-count');
          cartCountElements.forEach(el => {
            el.textContent = cart.item_count;
          });
        })
        .catch(error => console.error('Error fetching cart:', error));
    }
    
    showNotification(message, type = 'success') {
      const notification = document.createElement('div');
      notification.className = `notification notification-${type}`;
      notification.textContent = message;
      notification.style.cssText = `
        position: fixed;
        top: 20px;
        right: 20px;
        background: ${type === 'success' ? '#10B981' : '#EF4444'};
        color: white;
        padding: 12px 24px;
        border-radius: 8px;
        font-size: 14px;
        font-weight: 500;
        z-index: 9999;
        animation: slideIn 0.3s ease;
        box-shadow: 0 5px 25px rgba(0,0,0,0.2);
      `;
      
      document.body.appendChild(notification);
      
      setTimeout(() => {
        notification.style.animation = 'slideOut 0.3s ease';
        setTimeout(() => {
          notification.remove();
        }, 300);
      }, 2000);
    }
    
    init() {
      document.querySelectorAll('.add-to-cart-form').forEach(form => {
        form.addEventListener('submit', (e) => this.addToCart(e, form));
      });
    }
  }

  // ===========================================================================
  // Color Options Functionality
  // ===========================================================================
  class ColorOptionsManager {
    constructor() {
      this.init();
    }
    
    handleColorClick(dot) {
      // Remove active state from siblings
      const container = dot.parentElement;
      container.querySelectorAll('.color-dot').forEach(d => {
        d.style.borderColor = '';
        d.style.transform = '';
      });
      
      // Add active state to clicked dot
      dot.style.borderColor = 'var(--fc-primary)';
      dot.style.transform = 'scale(1.2)';
      
      // Show notification
      this.showNotification(`Color selected: ${dot.title || 'color'}`);
    }
    
    showNotification(message) {
      const notification = document.createElement('div');
      notification.className = 'notification notification-info';
      notification.textContent = message;
      notification.style.cssText = `
        position: fixed;
        top: 20px;
        right: 20px;
        background: #1A1A1A;
        color: white;
        padding: 12px 24px;
        border-radius: 8px;
        font-size: 14px;
        font-weight: 500;
        z-index: 9999;
        animation: slideIn 0.3s ease;
        box-shadow: 0 5px 25px rgba(0,0,0,0.2);
      `;
      
      document.body.appendChild(notification);
      
      setTimeout(() => {
        notification.style.animation = 'slideOut 0.3s ease';
        setTimeout(() => {
          notification.remove();
        }, 300);
      }, 1500);
    }
    
    init() {
      document.querySelectorAll('.color-dot').forEach(dot => {
        dot.addEventListener('click', (e) => {
          e.preventDefault();
          e.stopPropagation();
          this.handleColorClick(dot);
        });
      });
    }
  }

  // ===========================================================================
  // Lazy Loading for Images
  // ===========================================================================
  class LazyLoader {
    constructor() {
      if ('IntersectionObserver' in window) {
        this.initIntersectionObserver();
      } else {
        this.initFallback();
      }
    }
    
    initIntersectionObserver() {
      const imageObserver = new IntersectionObserver((entries, observer) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const img = entry.target;
            img.src = img.dataset.src;
            img.classList.add('loaded');
            observer.unobserve(img);
          }
        });
      });
      
      document.querySelectorAll('img[data-src]').forEach(img => {
        imageObserver.observe(img);
      });
    }
    
    initFallback() {
      // Simple fallback for older browsers
      document.querySelectorAll('img[data-src]').forEach(img => {
        img.src = img.dataset.src;
      });
    }
  }

  // ===========================================================================
  // Initialize all modules
  // ===========================================================================
  
  // Add animation styles
  const style = document.createElement('style');
  style.textContent = `
    @keyframes slideIn {
      from {
        transform: translateX(100%);
        opacity: 0;
      }
      to {
        transform: translateX(0);
        opacity: 1;
      }
    }
    
    @keyframes slideOut {
      from {
        transform: translateX(0);
        opacity: 1;
      }
      to {
        transform: translateX(100%);
        opacity: 0;
      }
    }
    
    .notification {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    }
  `;
  document.head.appendChild(style);
  
  // Initialize managers
  const wishlistManager = new WishlistManager();
  const quickViewManager = new QuickViewManager();
  const cartManager = new CartManager();
  const colorOptionsManager = new ColorOptionsManager();
  const lazyLoader = new LazyLoader();
  
  // Add loading class to cards for animation
  document.querySelectorAll('.product-card').forEach(card => {
    card.classList.add('loading');
    setTimeout(() => {
      card.classList.remove('loading');
    }, 500);
  });
  
  console.log('Featured Collection initialized successfully');
});
</script>

