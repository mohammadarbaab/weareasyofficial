<section class="featured-collection">
  <div class="page-width">
    
    {% if section.settings.heading != blank %}
      <h2 class="fc-heading">{{ section.settings.heading }}</h2>
    {% endif %}

    {% if section.settings.description != blank %}
      <p class="fc-description">{{ section.settings.description }}</p>
    {% endif %}

    {% if section.settings.products.size > 0 %}
      <div class="fc-grid">
        {% for product in section.settings.products limit: section.settings.products_limit %}
          <div class="fc-card">
            <a href="{{ product.url }}" class="fc-card-link">
              <div class="fc-image-wrapper">
                <div class="fc-image">
                  <img
                    src="{{ product.featured_image | image_url: width: 600 }}"
                    alt="{{ product.title | escape }}"
                    loading="lazy"
                  >
                </div>
              </div>
              <div class="fc-content">
                <h3 class="fc-title">{{ product.title }}</h3>
                <p class="fc-price">{{ product.price | money }}</p>
              </div>
            </a>
          </div>
        {% endfor %}
      </div>
    {% else %}
      <div class="fc-placeholder">
        <p>✨ Select products in the customizer to showcase your collection</p>
      </div>
    {% endif %}

  </div>
</section>

<style>
.featured-collection {
  padding: 80px 24px;
  background: linear-gradient(145deg, #ffffff 0%, #f9fafc 100%);
  overflow: hidden;
  position: relative;
}

/* subtle background ornament */
.featured-collection::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -10%;
  width: 600px;
  height: 600px;
  background: radial-gradient(circle, rgba(230, 240, 255, 0.6) 0%, rgba(255,255,255,0) 70%);
  border-radius: 50%;
  z-index: 0;
  pointer-events: none;
}

.page-width {
  max-width: 1400px;
  margin: 0 auto;
  position: relative;
  z-index: 2;
}

/* headings */
.fc-heading {
  font-size: clamp(32px, 5vw, 48px);
  font-weight: 700;
  letter-spacing: -0.02em;
  line-height: 1.1;
  margin: 0 0 16px 0;
  color: #0a1a2f;
  text-transform: none;
  opacity: 0;
  animation: fadeSlideUp 0.8s cubic-bezier(0.15, 0.85, 0.35, 1) forwards;
}

.fc-description {
  font-size: clamp(16px, 2.5vw, 18px);
  line-height: 1.6;
  margin: 0 0 48px 0;
  color: #4a5568;
  max-width: 600px;
  opacity: 0;
  animation: fadeSlideUp 0.8s 0.15s cubic-bezier(0.15, 0.85, 0.35, 1) forwards;
}

/* grid */
.fc-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 30px;
}

/* card styles */
.fc-card {
  background: white;
  border-radius: 28px;
  box-shadow: 0 15px 35px -10px rgba(0, 20, 40, 0.1);
  transition: transform 0.35s cubic-bezier(0.2, 0, 0, 1), box-shadow 0.4s ease;
  opacity: 0;
  animation: cardFadeIn 0.7s cubic-bezier(0.2, 0.9, 0.3, 1) forwards;
  animation-delay: calc(0.1s + (var(--card-index, 0) * 0.07s));
  transform-origin: center bottom;
  overflow: hidden;
  border: 1px solid rgba(230, 240, 255, 0.5);
  backdrop-filter: blur(2px);
}

/* staggered animation delay using loop */
{% for i in (1..12) %}
  .fc-card:nth-child({{ i }}) {
    --card-index: {{ i }};
  }
{% endfor %}

.fc-card:hover {
  transform: translateY(-12px) scale(1.02);
  box-shadow: 0 35px 55px -18px rgba(0, 40, 80, 0.25);
  border-color: rgba(180, 200, 255, 0.8);
}

.fc-card-link {
  text-decoration: none;
  color: inherit;
  display: block;
}

/* image wrapper for consistent aspect ratio */
.fc-image-wrapper {
  padding: 16px 16px 0 16px;
  background: white;
}

.fc-image {
  background: linear-gradient(145deg, #f0f4fe, #e9eefa);
  border-radius: 20px;
  overflow: hidden;
  aspect-ratio: 1 / 1;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.45s ease;
}

.fc-card:hover .fc-image {
  background: linear-gradient(145deg, #e6edfe, #dde6fe);
}

.fc-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.7s cubic-bezier(0.2, 0.8, 0.3, 1);
}

.fc-card:hover .fc-image img {
  transform: scale(1.08);
}

/* content */
.fc-content {
  padding: 20px 18px 24px 18px;
  background: white;
  border-radius: 0 0 28px 28px;
}

.fc-title {
  font-size: 16px;
  font-weight: 600;
  line-height: 1.4;
  margin: 0 0 6px 0;
  color: #12263a;
  text-transform: none;
  letter-spacing: 0.3px;
  transition: color 0.2s;
}

.fc-card:hover .fc-title {
  color: #1d4ed8;
}

.fc-price {
  font-size: 17px;
  font-weight: 500;
  margin: 0;
  color: #1f2a44;
  transition: color 0.2s;
  background: #f0f4ff;
  display: inline-block;
  padding: 5px 16px;
  border-radius: 60px;
  letter-spacing: 0.3px;
}

.fc-card:hover .fc-price {
  background: #1d4ed8;
  color: white;
}

/* placeholder style */
.fc-placeholder {
  background: rgba(255,255,255,0.8);
  border-radius: 60px;
  padding: 36px 24px;
  text-align: center;
  font-size: 18px;
  color: #2c3e5c;
  border: 2px dashed #b3c7f0;
  backdrop-filter: blur(5px);
  margin-top: 20px;
}

/* animations */
@keyframes fadeSlideUp {
  0% {
    opacity: 0;
    transform: translateY(35px);
  }
  100% {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes cardFadeIn {
  0% {
    opacity: 0;
    transform: translateY(45px) scale(0.96);
  }
  100% {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

/* Tablet */
@media (max-width: 1024px) {
  .featured-collection {
    padding: 64px 24px;
  }
  .fc-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }
  .fc-content {
    padding: 18px 14px 20px 14px;
  }
}

/* Mobile */
@media (max-width: 600px) {
  .featured-collection {
    padding: 48px 16px;
  }
  .fc-grid {
    grid-template-columns: 1fr;
    gap: 24px;
    max-width: 400px;
    margin: 0 auto;
  }
  .fc-heading {
    font-size: 28px;
  }
  .fc-description {
    margin-bottom: 36px;
  }
  .fc-image-wrapper {
    padding: 12px 12px 0 12px;
  }
  .fc-content {
    padding: 16px 12px 20px 12px;
  }
  .fc-price {
    font-size: 15px;
    padding: 4px 14px;
  }
}

/* very small devices */
@media (max-width: 380px) {
  .fc-content {
    padding: 14px 10px 18px;
  }
  .fc-title {
    font-size: 15px;
  }
}
</style>

{% schema %}
{
  "name": "Featured Products",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop Tees"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Lorem ipsum dolor sit amet, consectetur donec sodales sed nibh id vehicula."
    },
    {
      "type": "product_list",
      "id": "products",
      "label": "Select Products"
    },
    {
      "type": "range",
      "id": "products_limit",
      "label": "Products to show",
      "min": 1,
      "max": 12,
      "step": 1,
      "default": 4
    }
  ],
  "presets": [
    {
      "name": "Featured Products"
    }
  ]
}
{% endschema %}