{% assign section_id = 'new-collections-' | append: section.id %}

<section id="{{ section_id }}" class="new-collections">
  <div class="new-collections__inner">

    <!-- PREMIUM ARROWS WITH GLOW -->
    <button class="new-collections__arrow new-collections__arrow--prev" aria-label="Previous collection">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
    </button>

    <div class="new-collections__content">
      <!-- TYPOGRAPHY WITH ELEGANCE -->
      <h2 class="new-collections__title">{{ section.settings.title }}</h2>
      <p class="new-collections__description">{{ section.settings.description }}</p>

      <div class="new-collections__track-wrapper">
        <div class="new-collections__track">
          {% for block in section.blocks %}
            <div class="new-collections__item" {{ block.shopify_attributes }}>
              <div class="new-collections__image-wrap">
                {% if block.settings.image != blank %}
                  <img
                    src="{{ block.settings.image | img_url: '600x800', crop: 'center' }}"
                    alt="{{ block.settings.item_title }}"
                    class="new-collections__image"
                    loading="lazy"
                    width="600"
                    height="800"
                  >
                {% else %}
                  {{ 'image' | placeholder_svg_tag: 'new-collections__placeholder' }}
                {% endif %}
                <!-- soft overlay for depth -->
                <div class="new-collections__image-overlay"></div>
              </div>

              <div class="new-collections__item-body">
                <h3 class="new-collections__item-title">{{ block.settings.item_title }}</h3>
                <p class="new-collections__item-desc">{{ block.settings.item_description }}</p>
                <a href="{{ block.settings.button_url }}" class="new-collections__link">
                  <span>{{ block.settings.button_label }}</span>
                  <svg width="18" height="12" viewBox="0 0 18 12" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M1 6h14m-4-4 4 4-4 4"/></svg>
                </a>
              </div>
            </div>
          {% endfor %}
        </div>
      </div>
    </div>

    <button class="new-collections__arrow new-collections__arrow--next" aria-label="Next collection">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
    </button>

  </div>
</section>

<style>
/* ===== PREMIUM DESIGN SYSTEM ===== */
@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700&family=Montserrat:wght@300;400;500;600;700&display=swap');

#{{ section_id }} {
  --primary-dark: #1C1C1E;
  --secondary-gold: #B79B6E;
  --soft-beige: #F7F3EE;
  --text-rich: #2E2A27;
  --text-soft: #6B625A;
  --card-bg: #FFFFFF;
  --shadow-elegant: 0 20px 35px -10px rgba(0,0,0,0.08), 0 5px 12px rgba(0,0,0,0.02);
  --shadow-hover: 0 30px 45px -15px rgba(0,0,0,0.15);
  --transition-smooth: all 0.4s cubic-bezier(0.2, 0.9, 0.3, 1);

  background: var(--soft-beige);
  background-image: radial-gradient(circle at 0% 30%, rgba(183,155,110,0.03) 0%, transparent 30%),
                    radial-gradient(circle at 100% 80%, rgba(183,155,110,0.03) 0%, transparent 35%);
  padding: 70px 20px 90px;
  position: relative;
  overflow: hidden;
}

/* subtle texture overlay */
#{{ section_id }}::before {
  content: "";
  position: absolute;
  inset: 0;
  background-image: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23b79b6e' fill-opacity='0.02'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
  pointer-events: none;
  z-index: 0;
}

#{{ section_id }} .new-collections__inner {
  max-width: 1440px;
  margin: 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  z-index: 2;
  gap: 10px;
}

#{{ section_id }} .new-collections__content {
  flex: 1;
  min-width: 0;
  width: 100%;
}

/* ===== TITLE & DESCRIPTION ===== */
#{{ section_id }} .new-collections__title {
  font-family: 'Playfair Display', serif;
  font-size: clamp(42px, 7vw, 68px);
  font-weight: 600;
  letter-spacing: -0.02em;
  line-height: 1.1;
  text-align: center;
  margin: 0 0 15px;
  color: var(--primary-dark);
  position: relative;
  display: inline-block;
  width: 100%;
}

#{{ section_id }} .new-collections__title::after {
  content: '';
  position: relative;
  display: block;
  width: 90px;
  height: 3px;
  background: var(--secondary-gold);
  margin: 18px auto 0;
  border-radius: 4px;
}

#{{ section_id }} .new-collections__description {
  font-family: 'Montserrat', sans-serif;
  font-weight: 300;
  font-size: clamp(16px, 2.5vw, 18px);
  line-height: 1.8;
  color: var(--text-soft);
  max-width: 650px;
  margin: 0 auto 50px;
  text-align: center;
  letter-spacing: 0.02em;
  padding: 0 15px;
}

/* ===== CAROUSEL TRACK ===== */
#{{ section_id }} .new-collections__track-wrapper {
  overflow: hidden;
  border-radius: 24px;
  margin: 0 -5px;
  background-color: var(--soft-beige);
}

#{{ section_id }} .new-collections__track {
  display: flex;
  gap: 30px;
  transition: transform 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  will-change: transform;
}

/* ===== PRODUCT CARD ===== */
#{{ section_id }} .new-collections__item {
  flex: 0 0 calc((100% - 60px) / 3);
  background: var(--card-bg);
  border-radius: 28px;
  overflow: hidden;
  box-shadow: var(--shadow-elegant);
  transition: var(--transition-smooth);
  display: flex;
  flex-direction: column;
  border: 1px solid rgba(255,255,255,0.3);
  backdrop-filter: blur(2px);
}

#{{ section_id }} .new-collections__item:hover {
  transform: translateY(-8px);
  box-shadow: var(--shadow-hover);
}

/* image container */
#{{ section_id }} .new-collections__image-wrap {
  position: relative;
  aspect-ratio: 3/4;
  overflow: hidden;
  background: #f0eae3;
}

#{{ section_id }} .new-collections__image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 1.1s cubic-bezier(0.2, 0.9, 0.3, 1);
}

#{{ section_id }} .new-collections__item:hover .new-collections__image {
  transform: scale(1.07);
}

#{{ section_id }} .new-collections__image-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, transparent 50%, rgba(0,0,0,0.1) 100%);
  pointer-events: none;
  opacity: 0.3;
  transition: opacity 0.4s;
}

#{{ section_id }} .new-collections__item:hover .new-collections__image-overlay {
  opacity: 0.5;
}

/* placeholder svg */
#{{ section_id }} .new-collections__placeholder svg {
  width: 100%;
  height: 100%;
  background: #ddd6ce;
}

/* item body */
#{{ section_id }} .new-collections__item-body {
  padding: 24px 24px 28px;
  background: white;
  flex-grow: 1;
  display: flex;
  flex-direction: column;
}

#{{ section_id }} .new-collections__item-title {
  font-family: 'Montserrat', sans-serif;
  font-weight: 700;
  font-size: 20px;
  line-height: 1.3;
  letter-spacing: -0.01em;
  color: var(--primary-dark);
  margin: 0 0 10px;
  text-transform: none;
}

#{{ section_id }} .new-collections__item-desc {
  font-family: 'Montserrat', sans-serif;
  font-weight: 300;
  font-size: 15px;
  line-height: 1.7;
  color: var(--text-soft);
  margin: 0 0 20px;
  flex: 1;
}

/* elegant link with arrow */
#{{ section_id }} .new-collections__link {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  font-family: 'Montserrat', sans-serif;
  font-weight: 600;
  font-size: 14px;
  text-transform: uppercase;
  letter-spacing: 1.5px;
  color: var(--primary-dark);
  text-decoration: none;
  border-bottom: 1px solid transparent;
  transition: var(--transition-smooth);
  align-self: flex-start;
  margin-top: 5px;
}

#{{ section_id }} .new-collections__link svg {
  transition: transform 0.3s ease;
}

#{{ section_id }} .new-collections__link:hover {
  color: var(--secondary-gold);
  border-bottom-color: var(--secondary-gold);
}

#{{ section_id }} .new-collections__link:hover svg {
  transform: translateX(5px);
  stroke: var(--secondary-gold);
}

/* ===== ARROWS (elevated) ===== */
#{{ section_id }} .new-collections__arrow {
  background: white;
  border: none;
  width: 56px;
  height: 56px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  color: var(--primary-dark);
  box-shadow: 0 10px 20px -5px rgba(0,0,0,0.05), 0 0 0 1px rgba(183,155,110,0.2);
  transition: var(--transition-smooth);
  flex-shrink: 0;
  z-index: 5;
}

#{{ section_id }} .new-collections__arrow svg {
  width: 24px;
  height: 24px;
  stroke: currentColor;
}

#{{ section_id }} .new-collections__arrow:hover {
  background: var(--secondary-gold);
  color: white;
  box-shadow: 0 15px 25px -8px rgba(183,155,110,0.5);
  transform: scale(1.05);
}

#{{ section_id }} .new-collections__arrow--prev {
  margin-right: 5px;
}

#{{ section_id }} .new-collections__arrow--next {
  margin-left: 5px;
}

/* ===== RESPONSIVE PERFECTION ===== */
@media (max-width: 1024px) {
  #{{ section_id }} .new-collections__item {
    flex: 0 0 calc((100% - 24px) / 2);
  }
  #{{ section_id }} .new-collections__arrow {
    width: 48px;
    height: 48px;
  }
}

@media (max-width: 768px) {
  #{{ section_id }} {
    padding: 50px 16px 70px;
  }
  #{{ section_id }} .new-collections__inner {
    gap: 0;
  }
  #{{ section_id }} .new-collections__item {
    flex: 0 0 calc(100% - 10px);
  }
  #{{ section_id }} .new-collections__title,
  #{{ section_id }} .new-collections__description {
    display: block; /* keep for mobile but adjust */
  }
  #{{ section_id }} .new-collections__description {
    margin-bottom: 35px;
  }
  #{{ section_id }} .new-collections__arrow {
    width: 42px;
    height: 42px;
    background: rgba(255,255,255,0.9);
    backdrop-filter: blur(2px);
    box-shadow: 0 5px 15px rgba(0,0,0,0.1);
  }
  #{{ section_id }} .new-collections__arrow--prev {
    margin-right: 0;
    position: relative;
    left: 5px;
  }
  #{{ section_id }} .new-collections__arrow--next {
    margin-left: 0;
    position: relative;
    right: 5px;
  }
  #{{ section_id }} .new-collections__item-body {
    padding: 20px 18px 22px;
  }
  #{{ section_id }} .new-collections__item-title {
    font-size: 18px;
  }
  #{{ section_id }} .new-collections__item-desc {
    font-size: 14px;
  }
}

@media (max-width: 480px) {
  #{{ section_id }} .new-collections__title {
    font-size: 38px;
  }
  #{{ section_id }} .new-collections__description {
    font-size: 15px;
  }
  #{{ section_id }} .new-collections__arrow {
    width: 38px;
    height: 38px;
  }
  #{{ section_id }} .new-collections__arrow svg {
    width: 20px;
    height: 20px;
  }
}
</style>

<script>
(function() {
  var section = document.getElementById('{{ section_id }}');
  if (!section) return;

  var track = section.querySelector('.new-collections__track');
  var prevBtn = section.querySelector('.new-collections__arrow--prev');
  var nextBtn = section.querySelector('.new-collections__arrow--next');
  var isAnimating = false;
  var autoSlideInterval;
  var items = Array.from(track.children).filter(item => !item.classList.contains('clone'));

  // helper to get visible items count
  function getVisibleItems() {
    var width = window.innerWidth;
    if (width <= 768) return 1;
    if (width <= 1024) return 2;
    return 3;
  }

  // setup slider with cloning for infinite
  function setupSlider() {
    var visible = getVisibleItems();
    var gap = parseInt(getComputedStyle(track).gap) || 30;
    var trackWidth = track.offsetWidth;
    var itemWidth = (trackWidth - (visible - 1) * gap) / visible;

    // remove old clones
    track.querySelectorAll('.clone').forEach(c => c.remove());

    // reset items widths
    items.forEach(item => {
      item.style.flex = `0 0 ${itemWidth}px`;
    });

    // clone items (before and after)
    var total = items.length;
    for (var i = total - 1; i >= 0; i--) {
      var cloneBefore = items[i].cloneNode(true);
      cloneBefore.classList.add('clone');
      track.insertBefore(cloneBefore, items[0]);
    }
    for (var i = 0; i < total; i++) {
      var cloneAfter = items[i].cloneNode(true);
      cloneAfter.classList.add('clone');
      track.appendChild(cloneAfter);
    }

    track.style.transition = 'none';
    var offset = - (total * (itemWidth + gap));
    track.style.transform = `translateX(${offset}px)`;

    // re-assign items ref (after clones)
    items = Array.from(track.children).filter(item => !item.classList.contains('clone'));
  }

  // slide next
  function slideNext() {
    if (isAnimating) return;
    isAnimating = true;

    var visible = getVisibleItems();
    var gap = parseInt(getComputedStyle(track).gap) || 30;
    var trackWidth = track.offsetWidth;
    var itemWidth = (trackWidth - (visible - 1) * gap) / visible;
    var totalItems = items.length;

    var currentMatch = track.style.transform.match(/-?\d+\.?\d*/);
    var currentX = currentMatch ? parseFloat(currentMatch[0]) : 0;
    var newX = currentX - (itemWidth + gap);

    track.style.transition = 'transform 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94)';
    track.style.transform = `translateX(${newX}px)`;

    var transitionHandler = function() {
      track.style.transition = 'none';
      // move first item to end
      var firstClone = track.children[0];
      track.appendChild(firstClone);
      track.style.transform = `translateX(${newX + (itemWidth + gap)}px)`;
      isAnimating = false;
      track.removeEventListener('transitionend', transitionHandler);
    };
    track.addEventListener('transitionend', transitionHandler);
  }

  // slide prev
  function slidePrev() {
    if (isAnimating) return;
    isAnimating = true;

    var visible = getVisibleItems();
    var gap = parseInt(getComputedStyle(track).gap) || 30;
    var trackWidth = track.offsetWidth;
    var itemWidth = (trackWidth - (visible - 1) * gap) / visible;
    var totalItems = items.length;

    // move last item to beginning without transition
    var lastItem = track.children[track.children.length - 1];
    track.insertBefore(lastItem, track.children[0]);

    var currentMatch = track.style.transform.match(/-?\d+\.?\d*/);
    var currentX = currentMatch ? parseFloat(currentMatch[0]) : 0;
    track.style.transition = 'none';
    track.style.transform = `translateX(${currentX - (itemWidth + gap)}px)`;

    // Force reflow then animate back to currentX
    requestAnimationFrame(function() {
      requestAnimationFrame(function() {
        track.style.transition = 'transform 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94)';
        track.style.transform = `translateX(${currentX}px)`;
      });
    });

    var transitionHandler = function() {
      isAnimating = false;
      track.removeEventListener('transitionend', transitionHandler);
    };
    track.addEventListener('transitionend', transitionHandler);
  }

  // auto slide
  function startAutoSlide() {
    autoSlideInterval = setInterval(slideNext, 3000);
  }
  function resetAutoSlide() {
    clearInterval(autoSlideInterval);
    startAutoSlide();
  }

  // bind events
  nextBtn.addEventListener('click', function() {
    slideNext();
    resetAutoSlide();
  });
  prevBtn.addEventListener('click', function() {
    slidePrev();
    resetAutoSlide();
  });

  // resize handler
  var resizeTimer;
  window.addEventListener('resize', function() {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(function() {
      setupSlider();
    }, 150);
  });

  // initial setup
  setupSlider();
  startAutoSlide();
})();
</script>

{% schema %}
{
  "name": "New Collections",
  "tag": "section",
  "class": "section-new-collections",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "New Collections"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Discover our latest arrivals, crafted with timeless elegance and modern sophistication."
    }
  ],
  "blocks": [
    {
      "type": "collection_item",
      "name": "Collection Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "item_title",
          "label": "Item Title",
          "default": "Soft Leather Jackets"
        },
        {
          "type": "textarea",
          "id": "item_description",
          "label": "Item Description",
          "default": "Sculpted from premium lambskin, a modern icon for the discerning."
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button Label",
          "default": "Discover Now"
        },
        {
          "type": "url",
          "id": "button_url",
          "label": "Button URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "New Collections",
      "blocks": [
        { "type": "collection_item" },
        { "type": "collection_item" },
        { "type": "collection_item" }
      ]
    }
  ]
}
{% endschema %}