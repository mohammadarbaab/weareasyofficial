{% assign section_id = 'new-collections-' | append: section.id %}

<section id="{{ section_id }}" class="new-collections">
  <div class="new-collections__inner">

    <!-- PREMIUM ARROWS WITH ELEVATED GLOW & MICRO-INTERACTIONS -->
    <button class="new-collections__arrow new-collections__arrow--prev" aria-label="Previous collection">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
    </button>

    <div class="new-collections__content">
      <!-- TYPOGRAPHY WITH REFINED ELEGANCE & DECORATIVE DETAILS -->
      <h2 class="new-collections__title">{{ section.settings.title }}</h2>
      <p class="new-collections__description">{{ section.settings.description }}</p>

      <div class="new-collections__track-wrapper">
        <div class="new-collections__track">
          {% for block in section.blocks %}
            <div class="new-collections__item" {{ block.shopify_attributes }}>
              <div class="new-collections__image-wrap">
                {% if block.settings.image != blank %}
                  <img
                    src="{{ block.settings.image | img_url: '600x800', crop: 'center' }}"
                    alt="{{ block.settings.item_title }}"
                    class="new-collections__image"
                    loading="lazy"
                    width="600"
                    height="800"
                  >
                {% else %}
                  {{ 'image' | placeholder_svg_tag: 'new-collections__placeholder' }}
                {% endif %}
                <!-- soft overlay for depth + subtle vignette -->
                <div class="new-collections__image-overlay"></div>
              </div>

              <div class="new-collections__item-body">
                <h3 class="new-collections__item-title">{{ block.settings.item_title }}</h3>
                {% comment %} <p class="new-collections__item-desc">{{ block.settings.item_description }}</p> {% endcomment %}
                <a href="{{ block.settings.button_url }}" class="new-collections__link">
                  <span>{{ block.settings.button_label }}</span>
                  <svg width="18" height="12" viewBox="0 0 18 12" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M1 6h14m-4-4 4 4-4 4"/></svg>
                </a>
              </div>
            </div>
          {% endfor %}
        </div>
      </div>
    </div>

    <button class="new-collections__arrow new-collections__arrow--next" aria-label="Next collection">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
    </button>

  </div>
</section>

<style>
/* ===== UPGRADED DESIGN SYSTEM: CLASSIC, RICH, TIMELESS ===== */
@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700;800&family=Cormorant+Garamond:wght@300;400;500;600;700&display=swap');

#{{ section_id }} {
  --primary-deep: #1A1A1A;        /* deeper than before */
  --accent-gold: #A3895F;          /* refined gold */
  --background-warm: #F5F0E9;      /* warmer beige */
  --text-ebony: #2B2B2B;
  --text-mink: #5E5549;
  --card-pure: #FFFFFF;
  --shadow-elegant: 0 25px 40px -12px rgba(0,0,0,0.12), 0 6px 15px -8px rgba(0,0,0,0.02);
  --shadow-hover: 0 35px 55px -15px rgba(0,0,0,0.2), 0 8px 20px rgba(163, 137, 95, 0.1);
  --transition-classic: all 0.6s cubic-bezier(0.23, 1, 0.32, 1);

  background: var(--background-warm);
  background-image: 
    radial-gradient(circle at 10% 20%, rgba(163,137,95,0.03) 0%, transparent 25%),
    radial-gradient(circle at 90% 75%, rgba(163,137,95,0.03) 0%, transparent 30%);
  padding: 50px 20px 50px;
  position: relative;
  overflow: hidden;
  transition: transform 1.4s ease, opacity 1.4s ease;
}

/* refined texture – damask‑like pattern */
#{{ section_id }}::before {
  content: "";
  position: absolute;
  inset: 0;
  background-image: url("data:image/svg+xml,%3Csvg width='80' height='80' viewBox='0 0 80 80' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M40 20 L44 30 L55 30 L47 37 L51 48 L40 42 L29 48 L33 37 L25 30 L36 30 Z' fill='%23a3895f' fill-opacity='0.015' /%3E%3C/svg%3E");
  background-size: 120px 120px;
  opacity: 0.4;
  pointer-events: none;
  z-index: 0;
}

.new-collections__inner {
  max-width: 1440px;
  margin: 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  z-index: 2;
  gap: 15px;

  /* initial state for scroll animation */
  {% comment %} transform: scale(0.5); {% endcomment %}
  {% comment %} opacity: 0; {% endcomment %}
  {% comment %} transition: transform 1.5s ease-out, opacity 1.5s ease-out; {% endcomment %}
}

/* bloom effect – refined */
.new-collections__inner.bloom {
  transform: scale(1);
  opacity: 1;
}

#{{ section_id }} .new-collections__content {
  flex: 1;
  min-width: 0;
  width: 100%;
}

/* ===== TITLE WITH CLASSIC SERIF & GOLDEN TOUCHES ===== */
#{{ section_id }} .new-collections__title {
  font-family: 'Playfair Display', serif;
  font-size: clamp(48px, 8vw, 78px);
  font-weight: 700;
  letter-spacing: -0.02em;
  line-height: 1.05;
  text-align: center;
  margin: 0 0 15px;
  color: var(--primary-deep);
  position: relative;
  display: inline-block;
  width: 100%;
  text-transform: none;
}

#{{ section_id }} .new-collections__title::before {
  content: '';
  position: absolute;
  top: -18px;
  left: 50%;
  transform: translateX(-50%);
  width: 120px;
  height: 1px;
  background: linear-gradient(90deg, transparent, var(--accent-gold), transparent);
}

#{{ section_id }} .new-collections__title::after {
  content: '';
  position: relative;
  display: block;
  width: 110px;
  height: 2px;
  background: var(--accent-gold);
  margin: 20px auto 0;
  border-radius: 2px;
  box-shadow: 0 2px 6px rgba(163,137,95,0.3);
}

#{{ section_id }} .new-collections__description {
  font-family: 'Cormorant Garamond', serif;
  font-weight: 400;
  font-size: clamp(18px, 2.8vw, 22px);
  line-height: 1.7;
  color: var(--text-mink);
  max-width: 700px;
  margin: 0 auto 50px;
  text-align: center;
  letter-spacing: 0.02em;
  font-style: italic;
  padding: 0 20px;
}

/* ===== CAROUSEL TRACK WITH SMOOTH MASK ===== */
#{{ section_id }} .new-collections__track-wrapper {
  overflow: hidden;
  border-radius: 18px;
  margin: 0 -5px;
  background: transparent;
  mask: linear-gradient(90deg, transparent 0%, black 6%, black 94%, transparent 100%);

}

#{{ section_id }} .new-collections__track {
  display: flex;
  gap: 30px;
  transition: transform 0.9s cubic-bezier(0.2, 0.9, 0.3, 1);
  will-change: transform;
    max-width:1200px;
  padding: 12px 0 20px; /* space for shadow */
}

/* ===== PRODUCT CARD – TIMELESS ELEGANCE ===== */
#{{ section_id }} .new-collections__item {
  flex: 0 0 calc((100% - 60px) / 3);
  {% comment %} background: var(--card-pure); {% endcomment %}
  {% comment %} border-radius: 32px; {% endcomment %}
  overflow: hidden;
  {% comment %} box-shadow: var(--shadow-elegant); {% endcomment %}
  transition: var(--transition-classic);
  display: flex;
  flex-direction: column;
  border: 1px solid rgba(151, 143, 143, 0.4);
  backdrop-filter: blur(3px);
  transform: translateY(0);
}

#{{ section_id }} .new-collections__item:hover {
  transform: translateY(-10px) scale(1.01);
  {% comment %} box-shadow: var(--shadow-hover); {% endcomment %}
  border-color: rgba(163, 137, 95, 0.2);
}

/* image container – refined ratio & subtle border */
#{{ section_id }} .new-collections__image-wrap {
  position: relative;
  aspect-ratio: 3/4;
  overflow: hidden;
  background: #e1d7ce;
  border-bottom: 2px solid rgba(163, 137, 95, 0.15);
}

#{{ section_id }} .new-collections__image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 1.2s cubic-bezier(0.2, 0.9, 0.3, 1);
}

#{{ section_id }} .new-collections__item:hover .new-collections__image {
  transform: scale(1.08);
}

#{{ section_id }} .new-collections__image-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, transparent 50%, rgba(26, 26, 26, 0.2) 100%);
  pointer-events: none;
  opacity: 0.2;
  transition: opacity 0.5s;
  mix-blend-mode: multiply;
}

#{{ section_id }} .new-collections__item:hover .new-collections__image-overlay {
  opacity: 0.4;
}

/* placeholder svg */
#{{ section_id }} .new-collections__placeholder svg {
  width: 100%;
  height: 100%;
  background: #d6cdc2;
  fill: #aa9f94;
}

/* item body with classic typography */
#{{ section_id }} .new-collections__item-body {
  padding: 28px 28px 32px;
  background: white;
  flex-grow: 1;
  display: flex;
  flex-direction: column;
  background: linear-gradient(180deg, #ffffff 0%, #fefcf9 100%);
}

#{{ section_id }} .new-collections__item-title {
  font-family: 'Playfair Display', serif;
  font-weight: 600;
  font-size: 22px;
  line-height: 1.3;
  letter-spacing: -0.01em;
  color: var(--primary-deep);
  margin: 0 0 10px;
  text-transform: none;
  position: relative;
  display: inline-block;
}

#{{ section_id }} .new-collections__item-title::after {
  content: '';
  position: relative;
  display: block;
  width: 40px;
  height: 1px;
  background: var(--accent-gold);
  margin-top: 8px;
  transition: width 0.3s;
}

#{{ section_id }} .new-collections__item:hover .new-collections__item-title::after {
  width: 60px;
}

#{{ section_id }} .new-collections__item-desc {
  font-family: 'Cormorant Garamond', serif;
  font-weight: 400;
  font-size: 17px;
  line-height: 1.7;
  color: var(--text-mink);
  margin: 0 0 20px;
  flex: 1;
  font-style: normal;
}

/* elegant link with refined arrow animation */
#{{ section_id }} .new-collections__link {
  display: inline-flex;
  align-items: center;
  gap: 12px;
  font-family: 'Cormorant Garamond', serif;
  font-weight: 600;
  font-size: 15px;
  text-transform: uppercase;
  letter-spacing: 2px;
  color: var(--primary-deep);
  text-decoration: none;
  border-bottom: 1px solid transparent;
  transition: var(--transition-classic);
  align-self: flex-start;
  margin-top: 8px;
}

#{{ section_id }} .new-collections__link svg {
  transition: transform 0.4s ease;
  stroke-width: 1.8;
}

#{{ section_id }} .new-collections__link:hover {
  color: var(--accent-gold);
  border-bottom-color: var(--accent-gold);
}

#{{ section_id }} .new-collections__link:hover svg {
  transform: translateX(7px);
  stroke: var(--accent-gold);
}

/* ===== ARROWS (LUXURIOUS, WITH GLOW & SUBTLE SCALE) ===== */
#{{ section_id }} .new-collections__arrow {
  background: white;
  border: none;
  width: 60px;
  height: 60px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  color: var(--primary-deep);
  box-shadow: 0 12px 24px -8px rgba(0,0,0,0.1), 0 0 0 1px rgba(163,137,95,0.2);
  transition: var(--transition-classic);
  flex-shrink: 0;
  z-index: 5;
  backdrop-filter: blur(4px);
  background: rgba(255, 255, 255, 0.9);
}

#{{ section_id }} .new-collections__arrow svg {
  width: 26px;
  height: 26px;
  stroke: currentColor;
}

#{{ section_id }} .new-collections__arrow:hover {
  background: var(--accent-gold);
  color: white;
  box-shadow: 0 18px 30px -8px rgba(163, 137, 95, 0.5);
  transform: scale(1.08) translateY(-2px);
  border-color: transparent;
}

#{{ section_id }} .new-collections__arrow:active {
  transform: scale(0.98);
}

/* ===== RESPONSIVE PERFECTION (UPGRADED) ===== */
@media (max-width: 1024px) {
  #{{ section_id }} .new-collections__item {
    flex: 0 0 calc((100% - 24px) / 2);
  }
  #{{ section_id }} .new-collections__arrow {
    width: 52px;
    height: 52px;
  }
  #{{ section_id }} .new-collections__title {
    font-size: 64px;
  }
}

@media (max-width: 768px) {
  #{{ section_id }} {
    padding: 60px 16px 80px;
  }
  #{{ section_id }} .new-collections__inner {
    gap: 5px;
  }
  #{{ section_id }} .new-collections__item {
    flex: 0 0 calc(100% - 10px);
  }
  #{{ section_id }} .new-collections__track-wrapper {
    mask: linear-gradient(90deg, transparent 0%, black 3%, black 97%, transparent 100%);
  }
  #{{ section_id }} .new-collections__description {
    margin-bottom: 40px;
  }
  #{{ section_id }} .new-collections__arrow {
    width: 44px;
    height: 44px;
    background: rgba(255,255,255,0.95);
    box-shadow: 0 8px 20px rgba(0,0,0,0.12);
  }
  #{{ section_id }} .new-collections__arrow--prev {
    margin-right: 0;
    position: relative;
    left: 8px;
  }
  #{{ section_id }} .new-collections__arrow--next {
    margin-left: 0;
    position: relative;
    right: 8px;
  }
  #{{ section_id }} .new-collections__item-body {
    padding: 24px 20px 26px;
  }
  #{{ section_id }} .new-collections__item-title {
    font-size: 20px;
  }
  #{{ section_id }} .new-collections__item-desc {
    font-size: 16px;
  }
}

@media (max-width: 480px) {
  #{{ section_id }} .new-collections__title {
    font-size: 42px;
  }
  #{{ section_id }} .new-collections__title::before {
    width: 80px;
  }
  #{{ section_id }} .new-collections__description {
    font-size: 18px;
  }
  #{{ section_id }} .new-collections__arrow {
    width: 40px;
    height: 40px;
  }
  #{{ section_id }} .new-collections__arrow svg {
    width: 22px;
    height: 22px;
  }
}
</style>

<script>
(function() {
  var section = document.getElementById('{{ section_id }}');
  if (!section) return;

  var track = section.querySelector('.new-collections__track');
  var prevBtn = section.querySelector('.new-collections__arrow--prev');
  var nextBtn = section.querySelector('.new-collections__arrow--next');
  var isAnimating = false;
  var autoSlideInterval;
  var items = Array.from(track.children).filter(item => !item.classList.contains('clone'));

  // helper to get visible items count (dynamic)
  function getVisibleItems() {
    var width = window.innerWidth;
    if (width <= 768) return 1;
    if (width <= 1024) return 2;
    return 3;
  }

  // setup slider: infinite cloning with proper widths
  function setupSlider() {
    var visible = getVisibleItems();
    var gap = parseInt(getComputedStyle(track).gap) || 30;
    var trackWidth = track.offsetWidth;
    var itemWidth = (trackWidth - (visible - 1) * gap) / visible;

    // remove old clones
    track.querySelectorAll('.clone').forEach(c => c.remove());

    // set item widths
    items.forEach(item => {
      item.style.flex = `0 0 ${itemWidth}px`;
    });

    // clone items for infinite effect (append before and after)
    var total = items.length;
    for (var i = total - 1; i >= 0; i--) {
      var cloneBefore = items[i].cloneNode(true);
      cloneBefore.classList.add('clone');
      track.insertBefore(cloneBefore, items[0]);
    }
    for (var i = 0; i < total; i++) {
      var cloneAfter = items[i].cloneNode(true);
      cloneAfter.classList.add('clone');
      track.appendChild(cloneAfter);
    }

    // reset transform to show the first real item set
    track.style.transition = 'none';
    var offset = - (total * (itemWidth + gap));
    track.style.transform = `translateX(${offset}px)`;

    // re-assign items reference if needed elsewhere (but we keep items as original)
  }

  // slide next (infinite right to left)
  function slideNext() {
    if (isAnimating) return;
    isAnimating = true;

    var visible = getVisibleItems();
    var gap = parseInt(getComputedStyle(track).gap) || 30;
    var trackWidth = track.offsetWidth;
    var itemWidth = (trackWidth - (visible - 1) * gap) / visible;
    var totalItems = items.length;

    var currentMatch = track.style.transform.match(/-?\d+\.?\d*/);
    var currentX = currentMatch ? parseFloat(currentMatch[0]) : 0;
    var newX = currentX - (itemWidth + gap);

    track.style.transition = 'transform 0.9s cubic-bezier(0.2, 0.9, 0.3, 1)';
    track.style.transform = `translateX(${newX}px)`;

    var transitionHandler = function() {
      track.style.transition = 'none';
      // move first (clone or real) to the end to maintain infinite illusion
      var firstClone = track.children[0];
      track.appendChild(firstClone);
      track.style.transform = `translateX(${newX + (itemWidth + gap)}px)`;
      isAnimating = false;
      track.removeEventListener('transitionend', transitionHandler);
    };
    track.addEventListener('transitionend', transitionHandler, { once: true });
  }

  // slide prev (left to right)
  function slidePrev() {
    if (isAnimating) return;
    isAnimating = true;

    var visible = getVisibleItems();
    var gap = parseInt(getComputedStyle(track).gap) || 30;
    var trackWidth = track.offsetWidth;
    var itemWidth = (trackWidth - (visible - 1) * gap) / visible;

    // move last item to the front without transition
    var lastItem = track.children[track.children.length - 1];
    track.insertBefore(lastItem, track.children[0]);

    var currentMatch = track.style.transform.match(/-?\d+\.?\d*/);
    var currentX = currentMatch ? parseFloat(currentMatch[0]) : 0;
    track.style.transition = 'none';
    track.style.transform = `translateX(${currentX - (itemWidth + gap)}px)`;

    // force reflow and animate back to currentX
    requestAnimationFrame(function() {
      requestAnimationFrame(function() {
        track.style.transition = 'transform 0.9s cubic-bezier(0.2, 0.9, 0.3, 1)';
        track.style.transform = `translateX(${currentX}px)`;
      });
    });

    var transitionHandler = function() {
      isAnimating = false;
      track.removeEventListener('transitionend', transitionHandler);
    };
    track.addEventListener('transitionend', transitionHandler, { once: true });
  }

  // auto slide (right to left)
  function startAutoSlide() {
    autoSlideInterval = setInterval(slideNext, 2000); // smoother pace
  }
  function resetAutoSlide() {
    clearInterval(autoSlideInterval);
    startAutoSlide();
  }

  // bind events
  nextBtn.addEventListener('click', function() {
    slideNext();
    resetAutoSlide();
  });
  prevBtn.addEventListener('click', function() {
    slidePrev();
    resetAutoSlide();
  });

  // resize handler with debounce
  var resizeTimer;
  window.addEventListener('resize', function() {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(function() {
      setupSlider();
    }, 150);
  });

  // initial setup
  setupSlider();
  startAutoSlide();

  // pause on hover (luxury touch)
  track.addEventListener('mouseenter', function() {
    clearInterval(autoSlideInterval);
  });
  track.addEventListener('mouseleave', function() {
    startAutoSlide();
  });
})();

// Intersection Observer for "bloom" animation
document.addEventListener("DOMContentLoaded", function () {
  const sectionInner = document.querySelector("#{{ section_id }} .new-collections__inner");
  const observer = new IntersectionObserver(
    (entries, observer) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("bloom");
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.25 }
  );
  if (sectionInner) {
    observer.observe(sectionInner);
  }
});
</script>

{% schema %}
{
  "name": "New Collections",
  "tag": "section",
  "class": "section-new-collections",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "New Collections"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Discover our latest arrivals, crafted with timeless elegance and modern sophistication."
    }
  ],
  "blocks": [
    {
      "type": "collection_item",
      "name": "Collection Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "item_title",
          "label": "Item Title",
          "default": "Soft Leather Jackets"
        },
        {
          "type": "textarea",
          "id": "item_description",
          "label": "Item Description",
          "default": "Sculpted from premium lambskin, a modern icon for the discerning."
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button Label",
          "default": "Discover Now"
        },
        {
          "type": "url",
          "id": "button_url",
          "label": "Button URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "New Collections",
      "blocks": [
        { "type": "collection_item" },
        { "type": "collection_item" },
        { "type": "collection_item" }
      ]
    }
  ]
}
