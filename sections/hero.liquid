{% assign section_id = 'new-collections-' | append: section.id %}

<section id="{{ section_id }}" class="new-collections">
  <div class="new-collections__inner">

    <button class="new-collections__arrow new-collections__arrow--prev" aria-label="Previous">
      &#8592;
    </button>

    <div class="new-collections__content">
      <h2 class="new-collections__title">{{ section.settings.title }}</h2>
      <p class="new-collections__description">{{ section.settings.description }}</p>

      <div class="new-collections__track-wrapper">
        <div class="new-collections__track">
          {% for block in section.blocks %}
            <div class="new-collections__item" {{ block.shopify_attributes }}>
              <div class="new-collections__image-wrap">
                {% if block.settings.image != blank %}
                  <img
                    src="{{ block.settings.image | img_url: '600x800', crop: 'center' }}"
                    alt="{{ block.settings.item_title }}"
                    class="new-collections__image"
                    loading="lazy"
                    width="600"
                    height="800"
                  >
                {% else %}
                  {{ 'image' | placeholder_svg_tag: 'new-collections__placeholder' }}
                {% endif %}
              </div>

              <div class="new-collections__item-body">
                <h3 class="new-collections__item-title">
                  {{ block.settings.item_title }}
                </h3>
                <p class="new-collections__item-desc">
                  {{ block.settings.item_description }}
                </p>
                <a href="{{ block.settings.button_url }}" class="new-collections__link">
                  {{ block.settings.button_label }}
                </a>
              </div>
            </div>
          {% endfor %}
        </div>
      </div>
    </div>

    <button class="new-collections__arrow new-collections__arrow--next" aria-label="Next">
      &#8594;
    </button>

  </div>
</section>

<style>
#{{ section_id }} {
  background-color: #f0ede8;
  padding: 60px 0 80px;
  overflow: hidden;
}

#{{ section_id }} .new-collections__inner {
  max-width: 1440px;
  margin: 0 auto;
  padding: 0 60px;
  display: flex;
  align-items: flex-start;
}

#{{ section_id }} .new-collections__content {
  flex: 1;
  min-width: 0;
}

#{{ section_id }} .new-collections__title {
  font-family: Georgia, serif;
  font-size: 52px;
  text-align: center;
  margin-bottom: 24px;
}

#{{ section_id }} .new-collections__description {
  text-align: center;
  max-width: 600px;
  margin: 0 auto 48px;
  font-size: 14px;
  color: #888;
  line-height: 1.7;
}

#{{ section_id }} .new-collections__track-wrapper {
  overflow: hidden;
  position: relative;
  min-height: 400px; /* adjust if needed */
}

#{{ section_id }} .new-collections__track {
  position: relative;
  display: flex;
  gap: 40px;
}

#{{ section_id }} .new-collections__item {
  flex: 0 0 calc((100% - 80px) / 3);
  display: flex;
  flex-direction: column;
  opacity: 0;
  transform: scale(0.8);
  transition: opacity 0.5s ease, transform 0.5s ease;
  position: absolute;
  top: 0;
  left: 0;
}

#{{ section_id }} .new-collections__item.active {
  opacity: 1;
  transform: scale(1);
  position: relative;
}

#{{ section_id }} .new-collections__image-wrap {
  aspect-ratio: 3/4;
  overflow: hidden;
  margin-bottom: 20px;
}

#{{ section_id }} .new-collections__image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

#{{ section_id }} .new-collections__item-title {
  font-size: 13px;
  font-weight: 700;
  text-transform: uppercase;
  margin-bottom: 10px;
}

#{{ section_id }} .new-collections__item-desc {
  font-size: 13px;
  color: #888;
  margin-bottom: 16px;
}

#{{ section_id }} .new-collections__link {
  font-size: 12px;
  text-transform: uppercase;
  text-decoration: underline;
}

#{{ section_id }} .new-collections__arrow {
  background: none;
  border: none;
  cursor: pointer;
  font-size: 22px;
  padding: 0 15px;
  color: #aaa;
  margin-top: 220px;
}

#{{ section_id }} .new-collections__arrow:hover {
  color: #333;
}

/* Tablet */
@media (max-width: 992px) {
  #{{ section_id }} .new-collections__item {
    flex: 0 0 calc((100% - 24px) / 2);
  }
}

/* Mobile */
@media (max-width: 768px) {
  #{{ section_id }} .new-collections__arrow {
    display: none;
  }

  #{{ section_id }} .new-collections__item {
    flex: 0 0 100%;
  }
}
</style>

<script>
(function() {
  var section = document.getElementById('{{ section_id }}');
  if (!section) return;

  var track = section.querySelector('.new-collections__track');
  var prevBtn = section.querySelector('.new-collections__arrow--prev');
  var nextBtn = section.querySelector('.new-collections__arrow--next');

  var items = Array.from(track.children);
  var visibleCount = 3; // Adjust visible items per screen
  var currentIndex = 0;
  var isAnimating = false;

  // Initialize first active items
  function updateActive() {
    items.forEach((item, index) => {
      item.classList.remove('active');
      if (index >= currentIndex && index < currentIndex + visibleCount) {
        item.classList.add('active');
      }
    });
  }

  updateActive();

  function next() {
    if (isAnimating) return;
    isAnimating = true;

    // Reverse popup: remove active from current
    items.slice(currentIndex, currentIndex + visibleCount).forEach(item => {
      item.classList.remove('active');
    });

    // Move index
    currentIndex += visibleCount;
    if (currentIndex >= items.length) currentIndex = 0;

    // Popup effect for incoming items
    setTimeout(() => {
      updateActive();
      isAnimating = false;
    }, 50);
  }

  function prev() {
    if (isAnimating) return;
    isAnimating = true;

    items.slice(currentIndex, currentIndex + visibleCount).forEach(item => {
      item.classList.remove('active');
    });

    currentIndex -= visibleCount;
    if (currentIndex < 0) currentIndex = items.length - visibleCount;

    setTimeout(() => {
      updateActive();
      isAnimating = false;
    }, 50);
  }

  nextBtn.addEventListener('click', next);
  prevBtn.addEventListener('click', prev);

})();
</script>

