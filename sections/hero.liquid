{{ 'home-section.css' | asset_url | stylesheet_tag }}

<div class="home-collections">
  <div class="page-width">
    <div class="home-collections__header">
      <h2 class="home-collections__title">New Collections</h2>
      <p class="home-collections__description">Lorem ipsum dolor sit amet consectetur adipisicing elit. Saepe voluptas ut dolorum consequuntur, adipisci repellat! Eveniet commodi voluptatem voluptate, eum minima, in suscipit explicabo voluptatibus harum, quibusdam ex repellat eaque!</p>
    </div>

    <div class="home-collections__slider">
      <div class="slider__controls">
        <button class="slider__arrow slider__arrow--prev" aria-label="Previous slide">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M15 18L9 12L15 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <button class="slider__arrow slider__arrow--next" aria-label="Next slide">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M9 18L15 12L9 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>

      <div class="slider__container">
        <div class="slider__wrapper">
          {% for i in (1..3) %}
            {% assign image_setting = 'collection_image_' | append: i %}
            {% assign title_setting = 'collection_title_' | append: i %}
            {% assign description_setting = 'collection_description_' | append: i %}
            {% assign button_setting = 'collection_button_' | append: i %}
            {% assign link_setting = 'collection_link_' | append: i %}
            
            <div class="slider__slide">
              <div class="collection-card">
                <div class="collection-card__image">
                  {% if section.settings[image_setting] != blank %}
                    {{ section.settings[image_setting] | image_url: width: 600 | image_tag: loading: 'lazy' }}
                  {% else %}
                    {{ 'collection-image.png' | asset_url | img_tag: 'Collection image' }}
                  {% endif %}
                </div>
                <div class="collection-card__content">
                  <h3 class="collection-card__title">{{ section.settings[title_setting] | default: 'SOFT LEATHER JACKETS' }}</h3>
                  <p class="collection-card__description">{{ section.settings[description_setting] | default: 'Scelerisque duis aliquam qui lorem ipsum dolor amet, consectetur adipiscing elit.' }}</p>
                  <a href="{{ section.settings[link_setting] | default: '#' }}" class="collection-card__button">{{ section.settings[button_setting] | default: 'DISCOVER NOW' }}</a>
                </div>
              </div>
            </div>
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</div>

<style>
.home-collections {
  background-color: {{ section.settings.bg_color | default: '#ffffff' }};
  padding: {{ section.settings.padding_top | default: 60 }}px 0 {{ section.settings.padding_bottom | default: 60 }}px;
}

.page-width {
  max-width: 1440px;
  margin: 0 auto;
  padding: 0 20px;
}

.home-collections__header {
  text-align: center;
  margin-bottom: 50px;
}

.home-collections__title {
  font-size: 42px;
  line-height: 1.2;
  font-weight: 400;
  color: #000000;
  margin: 0 0 20px 0;
}

.home-collections__description {
  max-width: 800px;
  margin: 0 auto;
  font-size: 16px;
  line-height: 1.6;
  color: #666666;
}

.home-collections__slider {
  position: relative;
}

.slider__controls {
  position: absolute;
  top: 50%;
  left: 0;
  right: 0;
  transform: translateY(-50%);
  display: flex;
  justify-content: space-between;
  pointer-events: none;
  z-index: 2;
}

.slider__arrow {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  background-color: #ffffff;
  border: 1px solid #e5e5e5;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  pointer-events: auto;
  transition: all 0.3s ease;
  color: #000000;
}

.slider__arrow:hover {
  background-color: #f5f5f5;
  border-color: #cccccc;
}

.slider__arrow svg {
  width: 24px;
  height: 24px;
}

.slider__container {
  overflow: hidden;
}

.slider__wrapper {
  display: flex;
  transition: transform 0.5s ease;
}

.slider__slide {
  flex: 0 0 calc(33.333% - 20px);
  margin-right: 30px;
}

.collection-card {
  display: flex;
  flex-direction: column;
  background-color: #f8f8f8;
}

.collection-card__image {
  width: 100%;
  aspect-ratio: 1 / 1;
  overflow: hidden;
}

.collection-card__image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.collection-card__content {
  padding: 25px;
  text-align: center;
}

.collection-card__title {
  font-size: 24px;
  line-height: 1.3;
  font-weight: 400;
  color: #000000;
  margin: 0 0 15px 0;
}

.collection-card__description {
  font-size: 14px;
  line-height: 1.6;
  color: #666666;
  margin: 0 0 25px 0;
}

.collection-card__button {
  display: inline-block;
  padding: 12px 30px;
  background-color: transparent;
  border: 1px solid #000000;
  color: #000000;
  text-decoration: none;
  font-size: 14px;
  line-height: 1;
  letter-spacing: 1px;
  transition: all 0.3s ease;
}

.collection-card__button:hover {
  background-color: #000000;
  color: #ffffff;
}

/* Tablet */
@media screen and (max-width: 992px) {
  .slider__slide {
    flex: 0 0 calc(50% - 15px);
    margin-right: 30px;
  }
  
  .slider__slide:last-child {
    margin-right: 0;
  }
  
  .home-collections__title {
    font-size: 36px;
  }
}

/* Mobile */
@media screen and (max-width: 768px) {
  .slider__slide {
    flex: 0 0 100%;
    margin-right: 0;
  }
  
  .slider__controls {
    display: none;
  }
  
  .slider__wrapper {
    flex-direction: column;
    gap: 30px;
  }
  
  .home-collections__title {
    font-size: 28px;
  }
  
  .home-collections__description {
    font-size: 14px;
  }
  
  .collection-card__content {
    padding: 20px;
  }
  
  .collection-card__title {
    font-size: 20px;
  }
}

/* Small Mobile */
@media screen and (max-width: 480px) {
  .page-width {
    padding: 0 15px;
  }
  
  .collection-card__button {
    padding: 10px 20px;
    font-size: 12px;
  }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const slider = document.querySelector('.home-collections__slider');
  if (!slider) return;
  
  const wrapper = slider.querySelector('.slider__wrapper');
  const slides = slider.querySelectorAll('.slider__slide');
  const prevBtn = slider.querySelector('.slider__arrow--prev');
  const nextBtn = slider.querySelector('.slider__arrow--next');
  
  let currentIndex = 0;
  let slideWidth = 0;
  let slidesPerView = getSlidesPerView();
  
  function getSlidesPerView() {
    if (window.innerWidth <= 768) return 1;
    if (window.innerWidth <= 992) return 2;
    return 3;
  }
  
  function updateSlideWidth() {
    if (slides.length > 0) {
      const containerWidth = slider.querySelector('.slider__container').offsetWidth;
      slidesPerView = getSlidesPerView();
      const gap = slidesPerView > 1 ? 30 : 0;
      slideWidth = (containerWidth - (gap * (slidesPerView - 1))) / slidesPerView;
      
      slides.forEach(slide => {
        slide.style.flex = `0 0 ${slideWidth}px`;
      });
      
      if (slidesPerView === 1) {
        slides.forEach(slide => {
          slide.style.marginRight = '0';
        });
      } else {
        slides.forEach((slide, index) => {
          if (index < slides.length - 1) {
            slide.style.marginRight = '30px';
          } else {
            slide.style.marginRight = '0';
          }
        });
      }
    }
  }
  
  function updateSlider() {
    if (slidesPerView === 1) {
      // Fade effect for mobile
      slides.forEach((slide, index) => {
        if (index === currentIndex) {
          slide.style.opacity = '1';
          slide.style.visibility = 'visible';
          slide.style.position = 'relative';
        } else {
          slide.style.opacity = '0';
          slide.style.visibility = 'hidden';
          slide.style.position = 'absolute';
        }
      });
    } else {
      // Slide effect for desktop/tablet
      slides.forEach(slide => {
        slide.style.opacity = '1';
        slide.style.visibility = 'visible';
        slide.style.position = 'relative';
      });
      
      const gap = slidesPerView > 1 ? 30 : 0;
      const translateX = -currentIndex * (slideWidth + gap);
      wrapper.style.transform = `translateX(${translateX}px)`;
    }
  }
  
  function nextSlide() {
    const maxIndex = slides.length - slidesPerView;
    if (currentIndex < maxIndex) {
      currentIndex++;
      updateSlider();
    }
  }
  
  function prevSlide() {
    if (currentIndex > 0) {
      currentIndex--;
      updateSlider();
    }
  }
  
  // Initialize
  updateSlideWidth();
  updateSlider();
  
  // Set wrapper position relative for absolute positioned children on mobile
  if (slidesPerView === 1) {
    wrapper.style.position = 'relative';
  }
  
  // Event listeners
  nextBtn.addEventListener('click', nextSlide);
  prevBtn.addEventListener('click', prevSlide);
  
  window.addEventListener('resize', function() {
    const newSlidesPerView = getSlidesPerView();
    const wasMobile = slidesPerView === 1;
    const isMobile = newSlidesPerView === 1;
    
    slidesPerView = newSlidesPerView;
    
    if (wasMobile !== isMobile) {
      // Reset positions when switching between mobile and desktop
      currentIndex = 0;
      if (isMobile) {
        wrapper.style.position = 'relative';
        wrapper.style.transform = 'none';
      } else {
        wrapper.style.position = 'relative';
        slides.forEach(slide => {
          slide.style.position = 'relative';
          slide.style.opacity = '1';
          slide.style.visibility = 'visible';
        });
      }
    }
    
    updateSlideWidth();
    updateSlider();
  });
});
</script>

