<div class="video-container">

  {% if section.settings.video != blank %}
    {{
      section.settings.video
      | video_tag:
        autoplay: true,
        loop: true,
        muted: true,
        controls: false,
        playsinline: true,
        poster: section.settings.poster_image
    }}
  {% elsif section.settings.video_url != blank %}
    <video 
      autoplay 
      muted 
      loop 
      playsinline
      {% if section.settings.poster_image %}
        poster="{{ section.settings.poster_image | image_url: width: 2000 }}"
      {% endif %}
    >
      <source src="{{ section.settings.video_url }}" type="video/mp4">
    </video>
  {% endif %}

  <div class="overlay-content">
    <div class="content-inner">

      <span class="drop-tag">
        {{ section.settings.drop_tag }}
      </span>

      <h1 class="hero-title">
        {{ section.settings.title }}
      </h1>

      <p class="hero-subtext">
        {{ section.settings.subtext }}
      </p>

      <a href="{{ section.settings.button_link }}" class="shop-now-btn">
        <span>{{ section.settings.button_text }}</span>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
          <path d="M5 12H19M19 12L13 6M19 12L13 18" 
                stroke="currentColor" 
                stroke-width="2" 
                stroke-linecap="round" 
                stroke-linejoin="round"/>
        </svg>
      </a>

    </div>
  </div>

</div>

<style>
.video-container {
  position: relative;
  width: 100%;
  height: 70vh;
  overflow: hidden;
}

.video-container video {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.overlay-content {
  position: absolute;
  inset: 0;
  z-index: 2;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  background: rgba(0, 0, 0, 0.35);
}

.content-inner {
  max-width: 900px;
  padding: 0 20px;
  animation: fadeUp 1s ease forwards;
}

@keyframes fadeUp {
  from {
    opacity: 0;
    transform: translateY(30px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.drop-tag {
  display: inline-block;
  font-size: 14px;
  letter-spacing: 4px;
  text-transform: uppercase;
  color: rgba(255,255,255,0.85);
  padding: 8px 18px;
  border-radius: 40px;
  border: 1px solid rgba(255,255,255,0.3);
  margin-bottom: 20px;
}

.hero-title {
  color: #fff;
  font-size: clamp(48px, 10vw, 90px);
  margin: 0 0 10px;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: -2px;
}

.hero-subtext {
  color: #f0f0f0;
  font-size: clamp(16px, 3vw, 18px);
  margin-bottom: 35px;
  font-weight: 300;
  max-width: 600px;
  margin-left: auto;
  margin-right: auto;
}

.shop-now-btn {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  padding: 12px 28px;
  background: #EADBC8;
  color: #1a1a1a;
  text-decoration: none;
  font-weight: 600;
  font-size: 16px;
  text-transform: uppercase;
  border-radius: 50px;
  transition: 0.3s ease;
}

.shop-now-btn:hover {
  background: #fff;
  color: #000;
  gap: 16px;
}

.shop-now-btn svg {
  transition: transform 0.3s ease;
}

.shop-now-btn:hover svg {
  transform: translateX(5px);
}

@media (max-width: 768px) {
  .video-container {
    height: 70vh;
    min-height: 500px;
  }

  .hero-title {
    font-size: clamp(40px, 12vw, 70px);
  }

  .hero-subtext {
    font-size: 16px;
  }

  .shop-now-btn {
    padding: 12px 28px;
    font-size: 14px;
  }
}

@media (max-width: 480px) {
  .video-container {
    height: 60vh;
    min-height: 450px;
  }

  .hero-title {
    font-size: clamp(36px, 10vw, 50px);
  }

  .hero-subtext {
    font-size: 14px;
  }
}
</style>

{% schema %}
{
  "name": "Custom Video Hero",
  "settings": [
    {
      "type": "video",
      "id": "video",
      "label": "Video File"
    },
    {
      "type": "url",
      "id": "video_url",
      "label": "Video URL (MP4)"
    },
    {
      "type": "image_picker",
      "id": "poster_image",
      "label": "Poster Image"
    },
    {
      "type": "text",
      "id": "drop_tag",
      "label": "Drop Tag",
      "default": "Drop 2026"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Live. Now."
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtext",
      "default": "Limited styles. Unlimited confidence."
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link",
      "default": "/collections/all"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Shop Now"
    }
  ],
  "presets": [
    {
      "name": "Custom Video Hero",
      "category": "Hero"
    }
  ]
}
{% endschema %}