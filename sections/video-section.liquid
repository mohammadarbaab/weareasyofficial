<div class="custom-video-hero">
  <div class="video-wrapper">
    {% assign video_source = '' %}

    {% if section.settings.video != blank %}
      {% assign video_source = section.settings.video.sources[0].url %}
    {% elsif section.settings.video_url != blank %}
      {% assign video_source = section.settings.video_url %}
    {% else %}
      {% assign video_source = 'customvideo.mp4' | asset_url %}
    {% endif %}

    <video 
      autoplay 
      muted 
      loop 
      playsinline 
      preload="metadata"
      {% if section.settings.poster_image != blank %}
        poster="{{ section.settings.poster_image | image_url: width: 2000 }}"
      {% endif %}
    >
      <source src="{{ video_source }}" type="video/mp4">
    </video>
  </div>

  <div class="overlay-content">
    <div class="content-inner">
      <span class="drop-tag">
        {{ section.settings.drop_tag | default: 'Drop 2026' }}
      </span>

      <h1 class="hero-title">
        {{ section.settings.title | default: 'Live. Now.' }}
      </h1>

      <p class="hero-subtext">
        {{ section.settings.subtext | default: 'Limited styles. Unlimited confidence.' }}
      </p>

      <a href="{{ section.settings.button_link | default: '/collections/all' }}" class="shop-now-btn">
        <span>{{ section.settings.button_text | default: 'Shop Now' }}</span>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
          <path d="M5 12H19M19 12L13 6M19 12L13 18" 
                stroke="currentColor" 
                stroke-width="2" 
                stroke-linecap="round" 
                stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </div>
</div>

<style>
.custom-video-hero {
  position: relative;
  width: 100%;
  height: 80vh;
  min-height: 600px;
  overflow: hidden;
  background-color: #000;
}

.video-wrapper {
  position: absolute;
  inset: 0;
  z-index: 1;
}

.video-wrapper video {
  width: 100%;
  height: 100%;
  object-fit: cover;
  filter: brightness(0.75);
  transform: scale(1.02);
  transition: transform 0.5s ease;
}

.custom-video-hero:hover video {
  transform: scale(1.05);
}

.overlay-content {
  position: absolute;
  inset: 0;
  z-index: 2;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  background: rgba(0, 0, 0, 0.25);
  backdrop-filter: blur(3px);
}

.content-inner {
  max-width: 900px;
  padding: 0 20px;
  animation: fadeUp 1s ease forwards;
}

@keyframes fadeUp {
  from {
    opacity: 0;
    transform: translateY(30px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.drop-tag {
  display: inline-block;
  font-size: 14px;
  letter-spacing: 4px;
  text-transform: uppercase;
  color: rgba(255,255,255,0.85);
  padding: 8px 18px;
  border-radius: 40px;
  border: 1px solid rgba(255,255,255,0.2);
  margin-bottom: 20px;
}

.hero-title {
  color: #fff;
  font-size: clamp(48px, 10vw, 120px);
  margin: 0 0 10px;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: -2px;
}

.hero-subtext {
  color: #f0f0f0;
  font-size: clamp(16px, 3vw, 20px);
  margin-bottom: 35px;
  font-weight: 300;
  max-width: 600px;
  margin-left: auto;
  margin-right: auto;
}

.shop-now-btn {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  padding: 14px 36px;
  background: #EADBC8;
  color: #1a1a1a;
  text-decoration: none;
  font-weight: 600;
  font-size: 16px;
  text-transform: uppercase;
  border-radius: 50px;
  transition: 0.3s ease;
}

.shop-now-btn:hover {
  background: #fff;
  color: #000;
  gap: 16px;
}

.shop-now-btn svg {
  transition: transform 0.3s ease;
}

.shop-now-btn:hover svg {
  transform: translateX(5px);
}

@media (max-width: 768px) {
  .custom-video-hero {
    height: 70vh;
    min-height: 500px;
  }

  .hero-title {
    font-size: clamp(40px, 12vw, 70px);
  }

  .hero-subtext {
    font-size: 16px;
  }

  .shop-now-btn {
    padding: 12px 28px;
    font-size: 14px;
  }
}

@media (max-width: 480px) {
  .custom-video-hero {
    height: 60vh;
    min-height: 450px;
  }

  .hero-title {
    font-size: clamp(36px, 10vw, 50px);
  }

  .hero-subtext {
    font-size: 14px;
  }
}
</style>

{% schema %}
{
  "name": "Custom Video Hero",
  "settings": [
    {
      "type": "video",
      "id": "video",
      "label": "Video File"
    },
    {
      "type": "url",
      "id": "video_url",
      "label": "Video URL (MP4)"
    },
    {
      "type": "image_picker",
      "id": "poster_image",
      "label": "Poster Image (Recommended)"
    },
    {
      "type": "text",
      "id": "drop_tag",
      "label": "Drop Tag",
      "default": "Drop 2026"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Live. Now."
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtext",
      "default": "Limited styles. Unlimited confidence."
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link",
      "default": "/collections/all"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Shop Now"
    }
  ],
  "presets": [
    {
      "name": "Custom Video Hero",
      "category": "Hero"
    }
  ]
}
{% endschema %}